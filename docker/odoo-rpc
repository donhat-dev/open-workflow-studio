#!/usr/bin/env python3
"""
Odoo RPC Cron Worker — single-shot cron processor.

Mirrors the odoo.sh odoo-rpc mechanism:
- Starts server WITH HTTP to accept XML-RPC calls
- Patches ir_cron.acquire_job to process all pending jobs, then return False
- Supervisor triggers acquire_job via XML-RPC, then sends SIGTERM

Lifecycle (managed by supervisor):
  1. Supervisor spawns odoo-rpc periodically (CRON_INTERVAL)
  2. Server starts, registry loads, HTTP ready for XML-RPC
  3. Supervisor sends XML-RPC: ir.cron.acquire_job([])
  4. Patched acquire_job calls _process_jobs(db), returns False
  5. Supervisor sends SIGTERM → clean Odoo shutdown
  6. Supervisor reaps exit, schedules next spawn after CRON_INTERVAL
"""
import os
import sys

# Odoo source lives at /opt/odoo/source; add to path so `import odoo` works
sys.path.insert(0, "/opt/odoo/source")
os.environ.setdefault("PYTHONPYCACHEPREFIX", "/tmp/pycache")

import odoo
from odoo import SUPERUSER_ID


db = os.environ.get("PGDATABASE", "")
assert db, "PGDATABASE environment variable is required"


def acquire_job(self):
    """Process all pending cron jobs for this DB, then signal done."""
    self._process_jobs(db)
    return False


# ------------------------------------------------------------------
# Patches (mirrors odoo.sh: bypass auth, inject db/uid into dispatch)
# ------------------------------------------------------------------
odoo_dispatch = odoo.service.model.dispatch
odoo_logger = odoo.service.model._logger


def dispatch(method, params):
    """Inject db, SUPERUSER_ID, password=None into RPC dispatch."""
    try:
        return odoo_dispatch(method, [db, SUPERUSER_ID, None] + list(params))
    except Exception as e:
        msg = "method %s.%s failed during rpc call" % (params[0], params[1])
        odoo_logger.warning("%s: %s", msg, e)
        odoo_logger.debug(msg, exc_info=True)
        raise


if __name__ == "__main__":
    # Bypass RPC authentication for internal cron processing
    odoo.service.security.check = lambda db, uid, password: True
    odoo.service.model.dispatch = dispatch

    # Parse config from command-line args
    odoo.tools.config.parse_config(sys.argv[1:])

    # Patch cron to single-shot mode
    from odoo.addons.base.models import ir_cron
    ir_cron.ir_cron.acquire_job = acquire_job

    # Start server — HTTP + preload registry, then wait for XML-RPC trigger
    odoo.service.server.start(preload=[db])
