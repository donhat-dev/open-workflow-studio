# PostgreSQL (running on Windows host)
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo
POSTGRES_DB=hrm_pro_18

# Container identity (routing key — matches odoo.sh PGDATABASE pattern)
PGDATABASE=hrm_pro_18

# DB connection (control plane can override these)
# If the container cannot resolve host.docker.internal, replace DB_HOST with the
# resolved host IP from: getent hosts host.docker.internal | awk '{print $1; exit}'
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USER=odoo
DB_PASSWORD=odoo

# Odoo
ODOO_DEBUG=1
# Set DEBUGPY_ENABLE=1 to start HTTP worker with debugpy (e.g. VS Code attach)
DEBUGPY_ENABLE=0
DEBUGPY_PORT=5678
JWT_EXPIRE_TIME=999999
