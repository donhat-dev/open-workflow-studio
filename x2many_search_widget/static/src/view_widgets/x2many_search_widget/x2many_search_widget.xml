<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="x2many_search_widget.X2ManySearchWidget">
        <div class="o_x2many_search_widget input-group input-group-sm">
            <span class="input-group-text" title="Search">
                <i class="fa fa-search" aria-hidden="true"></i>
            </span>
            <input
                class="form-control"
                type="text"
                t-att-placeholder="props.placeholder"
                t-att-value="state.query"
                t-att-disabled="isDisabled"
                t-on-input="onInput"
            />
            <button
                t-if="showClearButton"
                type="button"
                class="btn btn-outline-secondary"
                t-on-click="onClear"
                aria-label="Clear search"
            >
                <i class="fa fa-times" aria-hidden="true"></i>
            </button>
        </div>
    </t>
</templates>
