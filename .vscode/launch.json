{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker: debug",
      "type": "debugpy",
      "request": "attach",
      "preLaunchTask": "supervisor:restart-worker:debug",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "logToFile": true,
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}",
          "remoteRoot": "/opt/odoo/open-workflow-studio"
        },
        {
          "localRoot": "/home/odoo/workspace/queue",
          "remoteRoot": "/opt/odoo/queue"
        },
        {
          "localRoot": "/home/odoo/workspace/hrm-odoo/addons/core",
          "remoteRoot": "/opt/odoo/hrm-odoo/addons/core"
        },
        {
          "localRoot": "/home/odoo/workspace/hrm-odoo/addons/hrm",
          "remoteRoot": "/opt/odoo/hrm-odoo/addons/hrm"
        },
        {
          "localRoot": "/home/odoo/workspace/hrm-odoo/addons/third_party",
          "remoteRoot": "/opt/odoo/hrm-odoo/addons/third_party"
        },
        {
          "localRoot": "/home/odoo/workspace/18EE-NS",
          "remoteRoot": "/opt/odoo/source"
        }
      ],
      "justMyCode": false
    },
    {
      "name": "hrm",
      "type": "debugpy",
      "request": "launch",
      "program": "/home/odoo/workspace/18EE-NS/odoo-bin",
      "python": "/home/odoo/workspace/.venv18/bin/python",
      "console": "integratedTerminal",
      "args": [
        "-c",
        "/home/odoo/workspace/config/odoo-hrm.conf",
        "--dev",
        "xml",
        "-d",
        "hrm_pro_18"
      ],
      "env": {
        "JWT_EXPIRE_TIME": "999999"
      },
      "justMyCode": true
    },
    {
      "name": "hrm (on demand restart)",
      "type": "debugpy",
      "request": "launch",
      "program": "C:\\Users\\ODOO\\Documents\\GitHub\\18EE-NS\\dev_server.py",
      "python": "C:\\Users\\ODOO\\Documents\\.venv18\\Scripts\\python.exe",
      "console": "integratedTerminal",
      "args": [
        "--",
        "-c",
        "C:\\Users\\ODOO\\Documents\\GitHub\\hrm-odoo\\.github\\odoo.conf",
        "--dev",
        "xml",
        "-d",
        "hrm_pro_18"
      ],
      "env": {
        "JWT_EXPIRE_TIME": "999999"
      },
      "justMyCode": true
    }
  ]
}
