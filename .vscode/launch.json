{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Docker: Odoo debug",
      "type": "debugpy",
      "request": "attach",
      "preLaunchTask": "docker-compose-restart",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/workflow_studio",
          "remoteRoot": "/opt/odoo/custom/workflow_studio"
        },
        {
          "localRoot": "${workspaceFolder}/flight_json_widget",
          "remoteRoot": "/opt/odoo/custom/flight_json_widget"
        },
        {
          "localRoot": "${workspaceFolder}/lf_web_studio",
          "remoteRoot": "/opt/odoo/custom/lf_web_studio"
        },
        {
          "localRoot": "C:/Users/ODOO/Documents/GitHub/18EE-NS",
          "remoteRoot": "/opt/odoo/source"
        }
      ],
      "justMyCode": true
    },
    {
      "name": "hrm",
      "type": "debugpy",
      "request": "launch",
      "program": "C:\\Users\\ODOO\\Documents\\GitHub\\18EE-NS\\odoo-bin",
      "python": "C:\\Users\\ODOO\\Documents\\.venv18\\Scripts\\python.exe",
      "console": "integratedTerminal",
      "args": [
        "-c",
        "C:\\Users\\ODOO\\Documents\\GitHub\\hrm-odoo\\.github\\odoo.conf",
        "--dev",
        "xml",
        "-d",
        "hrm_pro_18"
      ],
      "env": {
        "JWT_EXPIRE_TIME": "999999"
      },
      "justMyCode": true
    },
    {
      "name": "hrm (on demand restart)",
      "type": "debugpy",
      "request": "launch",
      "program": "C:\\Users\\ODOO\\Documents\\GitHub\\18EE-NS\\dev_server.py",
      "python": "C:\\Users\\ODOO\\Documents\\.venv18\\Scripts\\python.exe",
      "console": "integratedTerminal",
      "args": [
        "--",
        "-c",
        "C:\\Users\\ODOO\\Documents\\GitHub\\hrm-odoo\\.github\\odoo.conf",
        "--dev",
        "xml",
        "-d",
        "hrm_pro_18"
      ],
      "env": {
        "JWT_EXPIRE_TIME": "999999"
      },
      "justMyCode": true
    }
  ]
}
