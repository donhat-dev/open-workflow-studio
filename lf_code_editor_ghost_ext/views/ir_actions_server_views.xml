<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_server_action_form_lf_code_ghost" model="ir.ui.view">
        <field name="name">ir.actions.server.form.lf.code.ghost</field>
        <field name="model">ir.actions.server</field>
        <field name="inherit_id" ref="base.view_server_action_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='code' and @widget='code']" position="attributes">
                <attribute name="widget">lf_code_ghost</attribute>
                <attribute name="options">{'mode': 'python', 'suggestion_debug': True}</attribute>
            </xpath>
        </field>
    </record>
</odoo>
