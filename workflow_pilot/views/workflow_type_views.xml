<?xml version="1.0" encoding="UTF-8"?>
<odoo>
	<!-- =====================================================================
         WORKFLOW TYPE VIEWS
         Backend views for managing node type definitions
         ===================================================================== -->
	<!-- list View -->
	<record id="view_workflow_type_list" model="ir.ui.view">
		<field name="name">workflow.type.list</field>
		<field name="model">workflow.type</field>
		<field name="arch" type="xml">
			<list string="Node Types" default_order="category, sequence">
				<field name="sequence" widget="handle"/>
				<field name="name"/>
				<field name="node_type"/>
				<field name="category" widget="badge" decoration-info="category == 'trigger'" decoration-success="category == 'integration'" decoration-warning="category == 'flow'" decoration-danger="category == 'transform'" decoration-muted="category == 'data'"/>
				<field name="icon"/>
				<field name="color" widget="color"/>
				<field name="active" widget="boolean_toggle"/>
			</list>
		</field>
	</record>
	<!-- Form View -->
	<record id="view_workflow_type_form" model="ir.ui.view">
		<field name="name">workflow.type.form</field>
		<field name="model">workflow.type</field>
		<field name="arch" type="xml">
			<form string="Node Type">
				<sheet>
					<div class="oe_button_box" name="button_box">
						<field name="active" widget="boolean_button" options='{"terminology": "active"}'/>
					</div>
					<widget name="web_ribbon" title="Inactive" bg_color="text-bg-danger" invisible="active"/>
					<div class="oe_title">
						<label for="name"/>
						<h1>
							<field name="name" placeholder="Node Type Name"/>
						</h1>
					</div>
					<group>
						<group string="Basic Info">
							<field name="node_type" placeholder="e.g., http_request"/>
							<field name="category"/>
							<field name="sequence"/>
						</group>
						<group string="Display">
							<field name="icon" placeholder="e.g., globe, split"/>
							<field name="color" widget="color"/>
							<field name="group_id"/>
						</group>
					</group>
					<group>
						<field name="description" placeholder="Description shown in node palette..."/>
					</group>
					<notebook>
						<page string="Configuration Schema" name="config_schema">
							<field name="config_schema" widget="code" options="{'mode': 'xml'}"/>
						</page>
						<page string="Input Schema" name="input_schema">
							<field name="input_schema" widget="code" options="{'mode': 'xml'}"/>
						</page>
						<page string="Output Schema" name="output_schema">
							<field name="output_schema" widget="code" options="{'mode': 'xml'}"/>
						</page>
					</notebook>
				</sheet>
			</form>
		</field>
	</record>
	<!-- Kanban View -->
	<record id="view_workflow_type_kanban" model="ir.ui.view">
		<field name="name">workflow.type.kanban</field>
		<field name="model">workflow.type</field>
		<field name="arch" type="xml">
			<kanban class="o_kanban_small_column" default_group_by="category">
				<field name="name"/>
				<field name="node_type"/>
				<field name="category"/>
				<field name="icon"/>
				<field name="color"/>
				<field name="active"/>
				<templates>
					<t t-name="card">
						<div class="d-flex align-items-center gap-2">
							<span t-if="record.icon.raw_value" t-att-class="'fa fa-' + record.icon.raw_value" t-att-style="'color:' + (record.color.raw_value or '#666')"/>
							<strong>
								<field name="name"/>
							</strong>
						</div>
						<div class="text-muted small mt-1">
							<code>
								<field name="node_type"/>
							</code>
						</div>
						<div t-if="!record.active.raw_value" class="badge text-bg-danger mt-1">                            Inactive                        </div>
					</t>
				</templates>
			</kanban>
		</field>
	</record>
	<!-- Search View -->
	<record id="view_workflow_type_search" model="ir.ui.view">
		<field name="name">workflow.type.search</field>
		<field name="model">workflow.type</field>
		<field name="arch" type="xml">
			<search string="Search Node Types">
				<field name="name"/>
				<field name="node_type"/>
				<field name="category"/>
				<separator/>
				<filter name="active" string="Active" domain="[('active', '=', True)]"/>
				<filter name="inactive" string="Inactive" domain="[('active', '=', False)]"/>
				<separator/>
				<filter name="trigger" string="Trigger" domain="[('category', '=', 'trigger')]"/>
				<filter name="flow" string="Flow Control" domain="[('category', '=', 'flow')]"/>
				<filter name="integration" string="Integration" domain="[('category', '=', 'integration')]"/>
				<filter name="transform" string="Transform" domain="[('category', '=', 'transform')]"/>
				<filter name="data" string="Data" domain="[('category', '=', 'data')]"/>
				<group expand="0" string="Group By">
					<filter name="group_category" string="Category" context="{'group_by': 'category'}"/>
				</group>
			</search>
		</field>
	</record>
	<!-- Action -->
	<record id="action_workflow_type" model="ir.actions.act_window">
		<field name="name">Node Types</field>
		<field name="res_model">workflow.type</field>
		<field name="view_mode">list,kanban,form</field>
		<field name="search_view_id" ref="view_workflow_type_search"/>
		<field name="context">{'search_default_active': 1}</field>
		<field name="help" type="html">
			<p class="o_view_nocontent_smiling_face">                Create a new node type            </p>
			<p>                Node types define the available nodes in the workflow builder.                Each type has a configuration schema, input/output schema, and display properties.            </p>
		</field>
	</record>
	<!-- Configuration Menu -->
	<menuitem id="menu_workflow_config" name="Configuration" parent="workflow_pilot.menu_workflow_pilot_root" sequence="100"/>
	<!-- Menu Item (under Configuration) -->
	<menuitem id="menu_workflow_type" name="Node Types" parent="menu_workflow_config" action="action_workflow_type" sequence="10"/>
</odoo>