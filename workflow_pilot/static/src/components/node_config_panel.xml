<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="workflow_pilot.node_config_panel">
		<!-- Backdrop -->
		<div class="node-config-backdrop" t-on-click="onBackdropClick" t-on-wheel.stop="">
			<!-- Panel -->
			<div class="node-config-panel" t-ref="panel" t-att-class="{ 'panel-expanded': state.isExpanded }" t-att-style="panelStyle" t-on-wheel.stop="">
				<!-- Drag Resize Handle -->
				<div class="panel-resize-handle" t-on-mousedown="onResizeStart" title="Drag to resize">
					<div class="resize-handle-bar"/></div>
				<!-- Header -->
				<div class="node-config-header">
					<div class="node-config-title">
						<i t-att-class="'fa ' + nodeIcon"/>
						<span t-esc="nodeTitle"/>
					</div>
					<div class="node-config-actions">
						<!-- Expand/Collapse Toggle Button -->
						<button class="node-config-expand-btn" t-on-click="onToggleExpand" t-att-title="state.isExpanded ? 'Collapse panel' : 'Expand to full width'">
							<i t-att-class="'fa ' + (state.isExpanded ? 'fa-compress' : 'fa-expand')"/>
						</button>
						<button class="node-config-close" t-on-click="onClose" title="Close">
							<i class="fa fa-times"/>
						</button>
					</div>
				</div>
				<!-- Two Column Content -->
				<div class="node-config-content">
					<!-- LEFT PANEL: Ancestor Node Outputs -->
					<div class="node-config-left-panel">
						<div class="left-panel-header">
							<i class="fa fa-database"/>
							<span>INPUT</span>
						</div>
						<div class="left-panel-content">
							<!-- Show predecessor nodes with their outputs -->
							<t t-if="leftPanelData and leftPanelData.length > 0">
								<t t-foreach="leftPanelData" t-as="item" t-key="item.nodeId">
									<div class="ancestor-node-section" t-att-class="{ collapsed: isSectionCollapsed(item.nodeId) }">
										<div class="ancestor-node-header" t-on-click="() => this.toggleAncestorSection(item.nodeId)">
											<i t-att-class="'fa ' + (isSectionCollapsed(item.nodeId) ? 'fa-chevron-right' : 'fa-chevron-down')"/>
											<i t-att-class="item.isInputNode ? 'fa fa-sign-in' : 'fa fa-cube'"/>
											<t t-if="item.isInputNode">
												<span>
													<t t-esc="item.data.title"/>
												</span>
											</t>
											<t t-else="">
												<span t-esc="item.data.title"/>
											</t>
										</div>
										<div class="ancestor-node-data" t-if="!isSectionCollapsed(item.nodeId) and item.data.json !== undefined">
											<JsonTreeNode data="item.data.json" path="[]" isInputNode="item.isInputNode" sourceNodeId="item.isInputNode ? null : item.nodeId"/>
										</div>
										<div class="ancestor-node-data" t-elif="!isSectionCollapsed(item.nodeId)">
											<div class="input-data-empty">
												<span>No output data</span>
											</div>
										</div>
									</div>
								</t>
								<div class="ancestor-node-section context-section" t-att-class="{ collapsed: isSectionCollapsed('_context') }">
									<div class="ancestor-node-header" t-on-click="() => this.toggleAncestorSection('_context')">
										<i t-att-class="'fa ' + (isSectionCollapsed('_context') ? 'fa-chevron-right' : 'fa-chevron-down')"/>
										<i class="fa fa-code"/>
										<span>Variables and context</span>
									</div>
									<div class="ancestor-node-data" t-if="!isSectionCollapsed('_context') and contextVariables">
										<JsonTreeNode data="contextVariables or null" path="[]" draggable="true"/>
									</div>
								</div>
							</t>
							<t t-else="">
								<div class="input-data-empty input-data-hint">
									<i class="fa fa-database"/>
									<p>No input data</p>
									<span>Execute previous nodes to see data</span>
								</div>
							</t>
						</div>
						<div class="left-panel-footer"/></div>
					<!-- RIGHT PANEL: Node Configuration -->
					<div class="node-config-right-panel">
						<!-- Tabs -->
						<div class="node-config-tabs">
							<button class="node-config-tab" t-att-class="{ active: state.activeTab === 'parameters' }" t-on-click="() => this.onTabClick('parameters')">
								<i class="fa fa-sliders"/> Parameters
							
							</button>
							<button class="node-config-tab" t-att-class="{ active: state.activeTab === 'output' }" t-on-click="() => this.onTabClick('output')">
								<i class="fa fa-code"/> Output
							
							</button>
							<button class="node-config-tab" t-att-class="{ active: state.activeTab === 'settings' }" t-on-click="() => this.onTabClick('settings')">
								<i class="fa fa-cog"/> Settings
							
							</button>
						</div>
						<!-- Tab Content -->
						<div class="tab-content">
							<!-- Parameters Tab -->
							<t t-if="state.activeTab === 'parameters'">
								<t t-foreach="groupedControls" t-as="group" t-key="group.name">
									<div class="node-config-section">
										<div class="node-config-section-title" t-esc="group.name"/>
										<t t-foreach="group.controls" t-as="control" t-key="control.key">
											<ControlRenderer control="control" onChange.bind="onControlChange" inputContext="expressionPreviewContext" mode="getControlMode(control.key)" pairModes="getPairModes(control.key)" onModeChange.bind="onControlModeChange" onPairModeChange.bind="onPairModeChange"/>
										</t>
									</div>
								</t>
								<t t-if="groupedControls.length === 0">
									<div class="node-config-empty">
										No parameters to configure
									</div>
								</t>
							</t>
							<!-- Output Tab -->
							<t t-if="state.activeTab === 'output'">
								<div class="node-config-section">
									<div class="node-config-section-title">Execution Output</div>
									<t t-if="executionDisplayResult">
										<t t-if="executionDisplayResult.error">
											<JsonTreeNode data="executionDisplayResult.error" path="[]" draggable="false"/>
										</t>
										<t t-else="">
											<JsonTreeNode data="executionDisplayResult.output" path="[]" draggable="false"/>
										</t>
									</t>
									<t t-else="">
										<div class="input-data-empty">
											<i class="fa fa-terminal"/>
											<p>No output yet</p>
											<span>Click Execute to run this node</span>
										</div>
									</t>
								</div>
							</t>
							<!-- Settings Tab -->
							<t t-if="state.activeTab === 'settings'">
								<div class="node-config-section">
									<div class="node-config-section-title">Node Settings</div>
									<div class="control-renderer">
										<label class="control-label">Node Name</label>
										<input type="text" class="control-input" t-att-value="props.node.title || ''" placeholder="Enter node name..."/>
									</div>
								</div>
							</t>
						</div>
					</div>
				</div>
				<!-- Footer -->
				<div class="node-config-footer">
					<button class="node-config-btn secondary" t-on-click="onClose">
						Cancel
					</button>
					<button class="node-config-btn primary" t-on-click="onSave" t-att-disabled="!state.isDirty">
						Save
					</button>
				</div>
			</div>
		</div>
	</t>
</templates>
