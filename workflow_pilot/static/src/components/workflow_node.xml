<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
	<t t-name="workflow_pilot.workflow_node">
		<div class="workflow-node" t-ref="root" t-att-class="nodeTypeClass + (props.selected ? ' selected' : '') + (isDisabled ? ' disabled' : '')" t-att-style="nodeStyle" t-att-data-node-id="props.node.id" t-on-dblclick="onNodeDoubleClick">
			<CanvasNodeToolbar t-props="toolbarProps"/>
			<div class="workflow-node__header" t-on-mousedown="onHeaderMouseDown">
				<span class="workflow-node__icon">
					<LucideIcon t-props="{ name: nodeIcon, size: 16 }"/>
				</span>
				<span class="workflow-node__title">
					<t t-esc="props.node.title || props.node.type"/>
				</span>
			</div>
			<div class="workflow-node__body">
				<div class="workflow-node__sockets">
					<t t-foreach="socketRows" t-as="row" t-key="row_index">
						<div class="workflow-node__socket-row">
							<t t-if="row.input">
								<WorkflowSocket t-props="getInputSocketProps(row.input)"/>
							</t>
							<div t-else="" class="workflow-node__socket-spacer"/>
							<t t-if="row.output">
								<WorkflowSocket t-props="getOutputSocketProps(row.output)"/>
							</t>
							<div t-else="" class="workflow-node__socket-spacer"/></div>
					</t>
				</div>
			</div>
		</div>
	</t>
</templates>