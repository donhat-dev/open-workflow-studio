<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- 
            Built-in Node Types for Workflow Studio
            These match frontend definitions in static/src/nodes/
            
            Categories:
            - integration: External API integrations
            - flow: Control flow (loops, conditions)
            - transform: Data transformation
            - data: Variable/data operations
        -->

        <!-- Integration Nodes -->
        <record id="workflow_type_http" model="workflow.type">
            <field name="name">HTTP Request</field>
            <field name="node_type">http</field>
            <field name="category">integration</field>
            <field name="icon">fa-globe</field>
            <field name="description">Make HTTP API calls to external services</field>
            <field name="config_schema">{
    "method": {"type": "select", "options": ["GET", "POST", "PUT", "PATCH", "DELETE", "HEAD", "OPTIONS"], "default": "GET", "section": "request"},
    "url": {"type": "string", "required": true, "placeholder": "https://api.example.com/endpoint", "section": "request", "suggestions": ["https://api.example.com", "https://httpbin.org/anything"]},
    "query_params": {"type": "query_params", "label": "Query Params", "section": "request", "suggestionsByKey": {"limit": ["10", "20", "50", "100"], "offset": ["0", "10", "20"], "page": ["1", "2", "3"], "sort": ["asc", "desc"], "status": ["active", "inactive"]}},
    "auth": {"type": "auth", "label": "Authentication", "section": "authentication", "suggestionsByKey": {"header_name": ["Authorization", "X-API-Key"], "key_name": ["X-API-Key", "api_key"], "scope": ["read", "write", "read write"]}},
    "body_config": {"type": "body_type", "label": "Body", "section": "body", "visibleWhen": {"method": ["POST", "PUT", "PATCH"]}, "suggestionsByKey": {"form_data_value": ["true", "false", "null"]}},
    "headers": {"type": "keyvalue", "section": "headers", "suggestionsByKey": {"Content-Type": ["application/json", "application/x-www-form-urlencoded", "multipart/form-data"], "Accept": ["application/json", "*/*"], "Authorization": ["Bearer "]}},
    "timeout": {"type": "number", "default": 30, "min": 1, "max": 300, "label": "Timeout (seconds)", "section": "settings"},
    "follow_redirects": {"type": "checkbox", "default": true, "label": "Follow Redirects", "section": "settings"}
}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Input Data"}
}</field>
            <field name="output_schema">{
    "response": {"type": "DataSocket", "label": "Response"},
    "error": {"type": "ErrorSocket", "label": "Error"}
}</field>
        </record>

        <!-- Flow Control Nodes -->
        <record id="workflow_type_loop" model="workflow.type">
            <field name="name">Loop Over Items</field>
            <field name="node_type">loop</field>
            <field name="category">flow</field>
            <field name="icon">fa-repeat</field>
            <field name="description">Iterate over array items in batches</field>
            <field name="config_schema">{
    "inputItems": {"type": "expression", "label": "Input Items"},
    "batchSize": {"type": "number", "default": 1},
    "reset": {"type": "boolean", "default": false}
}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Data"}
}</field>
            <field name="output_schema">{
    "done": {"type": "DataSocket", "label": "Done"},
    "loop": {"type": "DataSocket", "label": "Loop"}
}</field>
        </record>

        <record id="workflow_type_if" model="workflow.type">
            <field name="name">If</field>
            <field name="node_type">if</field>
            <field name="category">flow</field>
            <field name="icon">split</field>
            <field name="description">Route data based on condition</field>
            <field name="config_schema">{
    "leftOperand": {"type": "expression", "label": "Left Operand"},
    "operator": {"type": "select", "options": ["eq", "neq", "gt", "gte", "lt", "lte", "contains", "startsWith", "endsWith", "empty", "notEmpty", "truthy", "falsy"], "default": "eq"},
    "rightOperand": {"type": "expression", "label": "Right Operand"}
}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Data"}
}</field>
            <field name="output_schema">{
    "true": {"type": "DataSocket", "label": "True"},
    "false": {"type": "DataSocket", "label": "False"}
}</field>
        </record>

        <record id="workflow_type_switch" model="workflow.type">
            <field name="name">Switch</field>
            <field name="node_type">switch</field>
            <field name="category">flow</field>
            <field name="icon">fa-random</field>
            <field name="description">Route data based on matching cases</field>
            <field name="config_schema">{
    "switchValue": {"type": "expression", "label": "Switch Value"},
    "case1": {"type": "expression", "label": "Case 1"},
    "case2": {"type": "expression", "label": "Case 2"},
    "case3": {"type": "expression", "label": "Case 3"}
}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Data"}
}</field>
            <field name="output_schema">{
    "case_1": {"type": "DataSocket", "label": "Case 1"},
    "case_2": {"type": "DataSocket", "label": "Case 2"},
    "case_3": {"type": "DataSocket", "label": "Case 3"},
    "default": {"type": "DataSocket", "label": "Default"}
}</field>
        </record>

        <record id="workflow_type_noop" model="workflow.type">
            <field name="name">Replace Me</field>
            <field name="node_type">noop</field>
            <field name="category">flow</field>
            <field name="icon">fa-circle-o</field>
            <field name="description">Placeholder node</field>
            <field name="config_schema">{}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Data"}
}</field>
            <field name="output_schema">{
    "result": {"type": "DataSocket", "label": "Result"}
}</field>
        </record>

        <!-- Trigger Nodes -->
        <record id="workflow_type_manual_trigger" model="workflow.type">
            <field name="name">Manual Trigger</field>
            <field name="node_type">manual_trigger</field>
            <field name="category">trigger</field>
            <field name="icon">fa-play</field>
            <field name="description">Manually start a workflow execution</field>
            <field name="config_schema">{}</field>
            <field name="input_schema">{}</field>
            <field name="output_schema">{
    "output": {"type": "DataSocket", "label": "Output"}
}</field>
        </record>

        <!-- Transform Nodes -->
        <record id="workflow_type_code" model="workflow.type">
            <field name="name">Code</field>
            <field name="node_type">code</field>
            <field name="category">transform</field>
            <field name="icon">fa-code</field>
            <field name="description">Execute Python code (set result for output)</field>
            <field name="config_schema">{
    "code": {"type": "code", "language": "python", "label": "Python Code"}
}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Input Data"}
}</field>
            <field name="output_schema">{
    "output": {"type": "DataSocket", "label": "Output"}
}</field>
        </record>

        <record id="workflow_type_validation" model="workflow.type">
            <field name="name">Data Validation</field>
            <field name="node_type">validation</field>
            <field name="category">transform</field>
            <field name="icon">fa-check-circle</field>
            <field name="description">Validate data against rules</field>
            <field name="config_schema">{
    "requiredFields": {"type": "string", "label": "Required Fields"},
    "schema": {"type": "json", "label": "Validation Schema"},
    "customRules": {"type": "keyvalue", "label": "Custom Rules"}
}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Input Data"}
}</field>
            <field name="output_schema">{
    "valid": {"type": "DataSocket", "label": "Valid Data"},
    "invalid": {"type": "ErrorSocket", "label": "Validation Errors"}
}</field>
        </record>

        <record id="workflow_type_set_data" model="workflow.type">
            <field name="name">Set Data</field>
            <field name="node_type">set_data</field>
            <field name="category">transform</field>
            <field name="icon">fa-pencil</field>
            <field name="description">Set or transform data fields</field>
            <field name="config_schema">{
    "fields": {"type": "keyvalue", "label": "Fields to Set"},
    "keepOnlySet": {"type": "select", "options": ["merge", "replace"], "default": "merge"}
}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Input Data"}
}</field>
            <field name="output_schema">{
    "output": {"type": "DataSocket", "label": "Output Data"}
}</field>
        </record>

        <!-- Data Nodes -->
        <record id="workflow_type_variable" model="workflow.type">
            <field name="name">Set Variable</field>
            <field name="node_type">variable</field>
            <field name="category">data</field>
            <field name="icon">fa-cube</field>
            <field name="description">Set or get workflow variables</field>
            <field name="config_schema">{
    "operation": {"type": "select", "options": ["set", "get", "append", "merge", "increment", "delete"], "default": "set"},
    "variableName": {"type": "string", "required": true, "label": "Variable Name"},
    "value": {"type": "expression", "label": "Value"}
}</field>
            <field name="input_schema">{
    "trigger": {"type": "DataSocket", "label": "Trigger"}
}</field>
            <field name="output_schema">{
    "output": {"type": "DataSocket", "label": "Output"}
}</field>
        </record>

        <record id="workflow_type_record_operation" model="workflow.type">
            <field name="name">Record Operation</field>
            <field name="node_type">record_operation</field>
            <field name="category">data</field>
            <field name="icon">fa-database</field>
            <field name="description">Search, create, write, or delete Odoo records</field>
            <field name="config_schema">{
    "operation": {"type": "select", "label": "Operation", "options": ["search", "create", "write", "delete"], "default": "search", "section": "operation"},
    "model": {"type": "model_select", "label": "Model", "required": true, "placeholder": "res.partner", "section": "operation"},
    "domain_expr": {"type": "domain", "label": "Domain", "default": "[]", "section": "target", "visibleWhen": {"operation": ["search", "write", "delete"]}},
    "ids_expr": {"type": "expression", "label": "Record IDs", "default": "={{ [] }}", "section": "target", "visibleWhen": {"operation": ["write", "delete"]}},
    "fields_expr": {"type": "expression", "label": "Fields", "default": "={{ ['id', 'display_name'] }}", "section": "search", "visibleWhen": {"operation": ["search"]}},
    "order": {"type": "string", "label": "Order", "placeholder": "id desc", "section": "search", "visibleWhen": {"operation": ["search"]}},
    "limit": {"type": "number", "label": "Limit", "default": 20, "min": 1, "max": 2000, "section": "search", "visibleWhen": {"operation": ["search", "write", "delete"]}},
    "vals_expr": {"type": "field_values", "label": "Values", "default": "{}", "section": "values", "visibleWhen": {"operation": ["create", "write"]}}
}</field>
            <field name="input_schema">{
    "data": {"type": "DataSocket", "label": "Input Data"}
}</field>
            <field name="output_schema">{
    "output": {"type": "DataSocket", "label": "Output"}
}</field>
        </record>

    </data>
</odoo>
