<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ================================ -->
    <!-- Security Groups                  -->
    <!-- ================================ -->

    <!-- Module Category -->
    <record id="module_category_workflow_pilot" model="ir.module.category">
        <field name="name">Workflow Studio</field>
        <field name="description">Workflow automation and integration</field>
        <field name="sequence">50</field>
    </record>

    <!-- Group: User (Base access) -->
    <record id="group_workflow_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_workflow_pilot"/>
        <field name="comment">Can create and edit own workflows</field>
    </record>

    <!-- Group: Manager (Implied from User) -->
    <record id="group_workflow_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="category_id" ref="module_category_workflow_pilot"/>
        <field name="implied_ids" eval="[(4, ref('group_workflow_user'))]"/>
        <field name="comment">Can view and edit all workflows in company</field>
    </record>

    <!-- Group: Admin (Implied from Manager) -->
    <record id="group_workflow_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_workflow_pilot"/>
        <field name="implied_ids" eval="[(4, ref('group_workflow_manager'))]"/>
        <field name="comment">Full access including node type management</field>
    </record>
</odoo>
