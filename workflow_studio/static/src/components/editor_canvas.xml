<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
	<t t-name="workflow_studio.editor_canvas">
		<div class="workflow-editor-canvas" t-ref="root" tabindex="0" t-att-style="canvasBackgroundStyle" t-on-dragover="onDragOver" t-on-drop="onDrop" t-on-click="onCanvasClick" t-on-mousedown="onCanvasMouseDown" t-on-wheel="onWheel" t-on-contextmenu="onCanvasContextMenu">
			<!-- Controls Bar (Top-Left) -->
			<div class="workflow-editor-canvas__controls d-flex align-items-center gap-1 p-2 rounded border shadow-sm bg-white" t-on-wheel.stop="">
				<t t-foreach="getButtonsWithDividers()" t-as="btn" t-key="btn.name">
					<t t-if="btn.divider">
						<div class="controls-divider"/>
					</t>
					<t t-else="">
						<t t-if="btn.menu">
							<div class="fit-view-dropdown position-relative d-inline-flex align-items-center" t-att-class="btn.menu.open ? 'is-open' : ''" t-on-click.stop="" t-on-mousedown.stop="" t-on-wheel.stop="">
								<button t-att-class="btn.classes + ' fit-view-dropdown__main'" t-on-click="btn.callback" t-att-disabled="btn.disabled ? 'disabled' : undefined" t-att-title="btn.title or ''">
									<t t-if="btn.icon">
										<LucideIcon t-props="{ name: btn.icon, size: btn.label ? 14 : 16 }"/>
									</t>
									<t t-if="btn.label"><span t-esc="btn.label"/></t>
								</button>
								<button class="btn btn-light btn-sm fit-view-dropdown__toggle" t-on-click="btn.menu.toggle" t-att-disabled="btn.menu.disabled ? 'disabled' : undefined" title="More fit options">
									<LucideIcon t-props="{ name: 'ChevronDown', size: 14 }"/>
								</button>
								<div class="fit-view-dropdown__menu" t-if="btn.menu.open" t-on-click.stop="" t-on-mousedown.stop="" t-on-wheel.stop="">
									<t t-foreach="btn.menu.items" t-as="item" t-key="item.key">
										<button class="fit-view-dropdown__item" t-on-click="item.callback" type="button">
											<LucideIcon t-props="{ name: item.icon, size: 14 }"/>
											<span t-esc="item.label"/>
										</button>
									</t>
								</div>
							</div>
						</t>
						<t t-else="">
							<button t-att-class="btn.classes" t-on-click="btn.callback" t-att-disabled="btn.disabled ? 'disabled' : undefined" t-att-title="btn.title or ''">
								<t t-if="btn.icon">
									<LucideIcon t-props="{ name: btn.icon, size: btn.label ? 14 : 16 }"/>
								</t>
								<t t-if="btn.label"><span t-esc="btn.label"/></t>
							</button>
						</t>
					</t>
				</t>
				<span class="zoom-label small text-muted fw-medium text-center px-1">
					<t t-esc="zoomPercentage"/>%
				</span>
			</div>
			<!-- Transformable content wrapper -->
			<div class="workflow-editor-canvas__content" t-att-style="viewportTransformStyle" t-ref="content">
				<!-- SVG Connection Layer -->
				<svg class="workflow-connections" t-ref="svgConnections">
					<defs>
						<marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto" markerUnits="strokeWidth">
							<polygon points="0 0, 10 3.5, 0 7" fill="currentColor"/>
						</marker>
					</defs>
					<!-- Render connection paths -->
					<t t-foreach="renderedConnections" t-as="conn" t-key="conn.id">
						<g class="workflow-connection-group" t-att-class="{ 'selected': selectedConnectionIds.includes(conn.id), 'vertical-stack': conn.isVerticalStack }" t-on-click.stop="() => this.onConnectionSelect(conn.id)" t-on-mouseenter="(ev) => this.handleConnectionEnter(ev, conn)" t-on-mouseleave="onConnectionMouseLeave">
							<t t-foreach="conn.paths" t-as="pathD" t-key="conn.id + '_' + pathD_index">
								<!-- Thicker invisible path for easier clicking -->
								<path t-att-d="pathD" class="workflow-connection-hitarea" stroke="transparent" stroke-width="12" fill="none" />
								<!-- Visible path (arrow only on last segment) -->
										<path t-att-d="pathD" t-att-data-connection-id="conn.id" t-att-class="'workflow-connection' + (conn.isBackEdge ? ' workflow-connection--back-edge' : '') + (conn.isVerticalStack ? ' workflow-connection--vertical-stack' : '') + (isConnectionExecuted(conn.id) ? ' workflow-connection--executed' : '')" stroke-width="2" fill="none" t-att-marker-end="pathD_last ? 'url(#arrowhead)' : undefined"/>
							</t>
						</g>
					</t>
					<!-- Temp connection line while drawing -->
					<path t-if="isDrawingConnection" t-att-d="tempConnectionPath" class="workflow-connection workflow-connection--temp" stroke-width="2" fill="none"/>
				</svg>
				<div class="workflow-editor-canvas__hint small text-muted text-center" t-if="nodes.length === 0">
					Drop nodes here (or click in the palette)
				</div>
				<t t-foreach="visibleNodes" t-as="node" t-key="node.id">
					<WorkflowNode t-props="getWorkflowNodeProps(node)"/>
				</t>
				<!-- Selection box -->
				<div t-if="gestures.state.isSelecting and selectionBoxStyle" class="workflow-editor-canvas__selection-box" t-att-style="selectionBoxStyle"/></div>
			<!-- Fixed-size overlays (positioned relative to canvas root, NOT affected by zoom/pan) -->
			<div class="workflow-editor-canvas__overlays">
				<!-- Connection Toolbar (on hover) -->
				<ConnectionToolbar t-if="hoveredConnection.id" position="hoveredConnection.midpoint" connectionId="hoveredConnection.id" zoom="viewport.zoom" onInsertNode="connectionToolbarProps.onInsertNode" onHoverChange="connectionToolbarProps.onHoverChange"/>
				<!-- Node Menu (context menu) - reads from service state via nodeMenu getter -->
				<NodeMenu t-if="nodeMenu.visible" position="{ x: nodeMenu.x, y: nodeMenu.y }" variant="nodeMenu.variant" connectionContext="nodeMenu.connectionContext" onNodeSelected="nodeMenuProps.onNodeSelected" onClose="nodeMenuProps.onClose"/>
			</div>
			<!-- Node Config Panel (outside content to avoid transform containment) -->
			<NodeConfigPanel t-if="isConfigPanelOpen and configPanelNode" node="configPanelNode" workflow="workflowData" actions="nodeConfigActions" execution="executionProp" viewMode="configPanelViewMode" onClose="onConfigPanelClose" onSave="onConfigPanelSave"/>
		</div>
	</t>
</templates>
