<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
	<t t-name="workflow_studio.workflow_node">
		<div class="workflow-node cursor-pointer d-flex flex-row" t-ref="root" t-att-class="nodeTypeClass + (props.selected ? ' selected' : '') + (isDisabled ? ' disabled' : '') + (isPinned ? ' wf-node--pinned' : '') + (executionClass ? ' ' + executionClass : '')"
		t-att-style="nodeStyle" t-att-data-node-id="props.node.id" t-on-dblclick="onNodeDoubleClick" t-on-mousedown="onHeaderMouseDown">
			<CanvasNodeToolbar t-if="toolbarProps" t-props="toolbarProps"/>

			<!-- Manual Trigger: Execute button (left side) -->
			<button t-if="isManualTrigger and !props.readonly"
				class="workflow-node__trigger-execute btn btn-sm d-flex align-items-center justify-content-center"
				t-on-click="onTriggerExecute"
				title="Execute from this trigger">
				<i class="fa fa-play me-1"/>
				<span>Execute</span>
			</button>

			<!-- Input sockets (absolute left) -->
			<div class="workflow-node__inputs" t-if="inputEntries.length">
				<t t-foreach="inputEntries" t-as="entry" t-key="entry[0]">
					<WorkflowSocket t-props="getInputSocketProps(entry)"/>
				</t>
			</div>

			<!-- Output sockets (absolute right) -->
			<div class="workflow-node__outputs" t-if="outputEntries.length">
				<t t-foreach="outputEntries" t-as="entry" t-key="entry[0]">
					<WorkflowSocket t-props="getOutputSocketProps(entry)"/>
				</t>
			</div>

			<!-- Card Content Layout -->
			<div class="workflow-node__icon-col">
				<div class="workflow-node__icon-box">
					<img t-if="isImageIcon" t-att-src="nodeIcon" class="workflow-node__icon-image" alt=""/>
					<i t-elif="isFontAwesomeIcon" t-att-class="fontAwesomeClass"/>
					<i t-else="" t-att-class="nodeIcon" style="font-size: 34px;"/>
				</div>
			</div>

			<div class="workflow-node__content-col">
				<span class="workflow-node__title o_text_overflow" t-att-title="displayTitle">
					<t t-esc="displayTitle"/>
				</span>

				<span class="workflow-node__subtitle o_text_overflow" t-att-title="props.node.type">
					<t t-esc="displaySubtitle"/>
				</span>
			</div>

			<!-- Execution Status Badge (bottom-right) -->
			<div t-if="props.executionStatus" t-att-class="'workflow-node__exec-badge workflow-node__exec-badge--' + props.executionStatus">
				<i t-if="props.executionStatus === 'running'" class="ms-1 fa fa-spinner fa-spin"/>
				<i t-elif="props.executionStatus === 'success'" class="ms-1 fa fa-check"/>
				<i t-else="" class="ms-1 fa fa-times-circle"/>
			</div>
		</div>
	</t>
</templates>
