<?xml version="1.0" encoding="utf-8"?>
<templates id="template" xml:space="preserve">
	<t t-name="workflow_studio.workflow_node">
		<div class="workflow-node cursor-pointer d-flex flex-row" t-ref="root" t-att-class="nodeTypeClass + (props.selected ? ' selected' : '') + (isDisabled ? ' disabled' : '') + (executionClass ? ' ' + executionClass : '')" t-att-style="nodeStyle" t-att-data-node-id="props.node.id" t-on-dblclick="onNodeDoubleClick" t-on-mousedown="onHeaderMouseDown">
			<CanvasNodeToolbar t-if="toolbarProps" t-props="toolbarProps"/>
			
			<!-- Input sockets (absolute left) -->
			<div class="workflow-node__inputs" t-if="inputEntries.length">
				<t t-foreach="inputEntries" t-as="entry" t-key="entry[0]">
					<WorkflowSocket t-props="getInputSocketProps(entry)"/>
				</t>
			</div>

			<!-- Output sockets (absolute right) -->
			<div class="workflow-node__outputs" t-if="outputEntries.length">
				<t t-foreach="outputEntries" t-as="entry" t-key="entry[0]">
					<WorkflowSocket t-props="getOutputSocketProps(entry)"/>
				</t>
			</div>

			<!-- Card Content Layout -->
			<div class="workflow-node__icon-col d-flex flex-column align-items-center justify-content-center ps-2 flex-shrink-0">
				<div class="workflow-node__icon-box d-flex align-items-center justify-content-center rounded-2">
					<img t-if="isImageIcon" t-att-src="nodeIcon" class="workflow-node__icon-image" alt=""/>
					<i t-elif="isFontAwesomeIcon" t-att-class="fontAwesomeClass"/>
					<LucideIcon t-else="" t-props="{ name: nodeIcon, size: 34 }"/>
				</div>
			</div>

			<div class="workflow-node__content-col d-flex flex-column justify-content-center py-2 pe-2 min-w-0">
				<div class="workflow-node__header-row d-flex justify-content-between align-items-start mb-1">
					<span class="workflow-node__title o_text_overflow text-body fw-semibold pe-1" t-att-title="props.node.title || props.node.type">
						<t t-esc="props.node.title || props.node.type"/>
					</span>
				</div>
				
				<div class="workflow-node__subtitle small text-muted font-monospace o_text_overflow mb-1">
					<t t-esc="props.node.type"/>
				</div>

				<!-- Footer actions removed -->
			</div>

			<!-- Execution Status Badge (bottom-right) -->
			<div t-if="props.executionStatus" t-att-class="'workflow-node__exec-badge workflow-node__exec-badge--' + props.executionStatus">
				<i t-if="props.executionStatus === 'running'" class="ms-1 fa fa-spinner fa-spin"/>
				<i t-elif="props.executionStatus === 'success'" class="ms-1 fa fa-check"/>
				<i t-else="" class="ms-1 fa fa-times-circle"/>
			</div>
		</div>
	</t>
</templates>