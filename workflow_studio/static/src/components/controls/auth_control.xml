<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="workflow_studio.auth_control">
        <div class="auth-control">
            <!-- Auth Type Selector -->
            <div class="auth-type-selector">
                <select class="control-select" t-on-change="onTypeChange" t-att-disabled="props.readonly ? 'disabled' : undefined">
                    <t t-foreach="authTypes" t-as="at" t-key="at.value">
                        <option t-att-value="at.value" t-att-selected="at.value === authType" t-esc="at.label"/>
                    </t>
                </select>
            </div>

            <!-- None: no fields -->
            <t t-if="authType === 'none'">
                <div class="auth-info text-muted small mt-2">
                    <i class="fa fa-info-circle"/> This request does not use any authorization.
                </div>
            </t>

            <!-- Bearer Token -->
            <t t-elif="authType === 'bearer'">
                <div class="auth-fields auth-fields--single mt-2">
                    <div class="auth-field auth-field--full">
                        <ExpressionInput label="'Token'" value="getField('token')" placeholder="placeholders.bearerToken" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('token')" valueSuggestions="getFieldSuggestions('token')" onChange="(v) => this.onFieldChange('token', v)" readonly="props.readonly"/>
                    </div>
                </div>
            </t>

            <!-- Basic Auth -->
            <t t-elif="authType === 'basic'">
                <div class="auth-fields auth-fields--two mt-2">
                    <div class="auth-field">
                        <ExpressionInput label="'Username'" value="getField('username')" placeholder="placeholders.username" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('username')" valueSuggestions="getFieldSuggestions('username')" onChange="(v) => this.onFieldChange('username', v)" readonly="props.readonly"/>
                    </div>
                    <div class="auth-field">
                        <ExpressionInput label="'Password'" value="getField('password')" placeholder="placeholders.password" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('password')" valueSuggestions="getFieldSuggestions('password')" onChange="(v) => this.onFieldChange('password', v)" readonly="props.readonly"/>
                    </div>
                </div>
            </t>

            <!-- API Key -->
            <t t-elif="authType === 'api_key'">
                <div class="auth-fields auth-fields--three mt-2">
                    <div class="auth-field">
                        <ExpressionInput label="'Key'" value="getField('key_name')" placeholder="placeholders.apiKeyName" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('key_name')" valueSuggestions="getFieldSuggestions('key_name')" onChange="(v) => this.onFieldChange('key_name', v)" readonly="props.readonly"/>
                    </div>
                    <div class="auth-field">
                        <ExpressionInput label="'Value'" value="getField('key_value')" placeholder="placeholders.apiKeyValue" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('key_value')" valueSuggestions="getFieldSuggestions('key_value')" onChange="(v) => this.onFieldChange('key_value', v)" readonly="props.readonly"/>
                    </div>
                    <div class="auth-field auth-field--select">
                        <label class="control-label">Add to</label>
                        <select class="control-select" t-on-change="(ev) => this.onSelectFieldChange('key_location', ev)" t-att-disabled="props.readonly ? 'disabled' : undefined">
                            <t t-foreach="apiKeyLocations" t-as="loc" t-key="loc.value">
                                <option t-att-value="loc.value" t-att-selected="loc.value === (getField('key_location') or 'header')" t-esc="loc.label"/>
                            </t>
                        </select>
                    </div>
                </div>
            </t>

            <!-- OAuth 2.0 -->
            <t t-elif="authType === 'oauth2'">
                <div class="auth-fields auth-fields--oauth mt-2">
                    <div class="auth-field auth-field--full">
                        <ExpressionInput label="'Access Token'" value="getField('access_token')" placeholder="placeholders.accessToken" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('access_token')" valueSuggestions="getFieldSuggestions('access_token')" onChange="(v) => this.onFieldChange('access_token', v)" readonly="props.readonly"/>
                    </div>
                    <div class="auth-field auth-field--full">
                        <ExpressionInput label="'Token URL'" value="getField('token_url')" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('token_url')" valueSuggestions="getFieldSuggestions('token_url')" onChange="(v) => this.onFieldChange('token_url', v)" readonly="props.readonly"/>
                    </div>
                    <div class="auth-field">
                        <ExpressionInput label="'Client ID'" value="getField('client_id')" placeholder="placeholders.clientId" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('client_id')" valueSuggestions="getFieldSuggestions('client_id')" onChange="(v) => this.onFieldChange('client_id', v)" readonly="props.readonly"/>
                    </div>
                    <div class="auth-field">
                        <ExpressionInput label="'Client Secret'" value="getField('client_secret')" placeholder="placeholders.clientSecret" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('client_secret')" valueSuggestions="getFieldSuggestions('client_secret')" onChange="(v) => this.onFieldChange('client_secret', v)" readonly="props.readonly"/>
                    </div>
                    <div class="auth-field auth-field--full">
                        <ExpressionInput label="'Scope'" value="getField('scope')" placeholder="placeholders.scope" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('scope')" valueSuggestions="getFieldSuggestions('scope')" onChange="(v) => this.onFieldChange('scope', v)" readonly="props.readonly"/>
                    </div>
                </div>
            </t>

            <!-- Custom Header -->
            <t t-elif="authType === 'custom_header'">
                <div class="auth-fields auth-fields--two mt-2">
                    <div class="auth-field">
                        <ExpressionInput label="'Header Name'" value="getField('header_name')" placeholder="placeholders.headerName" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('header_name')" valueSuggestions="getFieldSuggestions('header_name')" onChange="(v) => this.onFieldChange('header_name', v)" readonly="props.readonly"/>
                    </div>
                    <div class="auth-field">
                        <ExpressionInput label="'Header Value'" value="getField('header_value')" placeholder="placeholders.headerValue" context="props.inputContext" toggleMode="'side'" suggestions="getFieldSuggestions('header_value')" valueSuggestions="getFieldSuggestions('header_value')" onChange="(v) => this.onFieldChange('header_value', v)" readonly="props.readonly"/>
                    </div>
                </div>
            </t>
        </div>
    </t>
</templates>
