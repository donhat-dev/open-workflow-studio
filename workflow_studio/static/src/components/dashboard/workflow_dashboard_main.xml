<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-name="workflow_studio.WorkflowDashboardMain">
        <div class="o_workflow_dashboard_main o_action d-flex flex-column h-100">
            <t t-if="state.loading">
                <div class="d-flex justify-content-center align-items-center flex-grow-1">
                    <i class="fa fa-3x fa-spin fa-spinner text-muted"/>
                </div>
            </t>
            <t t-else="">
                <!-- Full-width stat bar (fixed height, Purchase pattern) -->
                <WorkflowDashboardSummary data="dashboardData.summary" onNavigate.bind="onNavigate"/>

                <!-- DashboardNotebook: base shell providing scrollable container -->
                <DashboardNotebook className="'p-3 flex-grow-1 d-flex flex-column'">
                    <!-- ─── Data zone: chart + lists ─── -->
                    <div class="row g-2 flex-grow-1 m-0 h-100" style="min-height: 320px;">
                        <!-- Left column: execution chart (full height) -->
                        <div class="col-12 col-lg-6 d-flex flex-column h-100 p-0 pe-lg-1 gap-2">
                            <div class="o_wf_card_slot">
                                <DashboardBlock>
                                    <t t-call="workflow_studio.WorkflowDashboardMain.Summary"/>
                                </DashboardBlock>
                            </div>
                            <div class="o_wf_card_slot">
                                <WorkflowDashboardStats title="'Execution Runs'" type="'stacked_bar'" data="dashboardData.runs" toggleOptions="runChartToggleOptions" defaultToggle="'7d'"/>
                            </div>
                        </div>

                        <!-- Right column: errors + recent activity -->
                        <div class="col-12 col-lg-6 d-flex flex-column h-100 p-0 ps-lg-1 gap-2">
                            <div class="o_wf_card_slot">
                                <DashboardBlock scrollable="true" blockClass="'o_workflow_dashboard_block'">
                                    <WorkflowList actionXmlId="'workflow_studio.action_workflow_run_errors'" viewType="'list'" context="{'create': false}" limit="7"/>
                                </DashboardBlock>
                            </div>
                            <div class="o_wf_card_slot">
                                <DashboardBlock scrollable="true" blockClass="'o_workflow_dashboard_block'">
                                    <WorkflowList actionXmlId="'workflow_studio.action_workflow_run_activity'" viewType="'list'" context="{'create': false}" limit="7"/>
                                </DashboardBlock>
                            </div>
                        </div>
                    </div>
                </DashboardNotebook>
            </t>
        </div>
    </t>
    <t t-name="workflow_studio.WorkflowDashboardMain.Summary">
        <div class="wf-dashboard-hero mb-3">
            <div class="wf-eyebrow">Welcome To</div>
            <h2 class="wf-detail-title">
                <span class="wf-framed-text">
                    <span class="wf-corner wf-corner--tl" aria-hidden="true"/>
                    <span class="wf-corner wf-corner--tr" aria-hidden="true"/>
                    <span class="wf-corner wf-corner--bl" aria-hidden="true"/>
                    <span class="wf-corner wf-corner--br" aria-hidden="true"/>
                                        Workflow Automation Studio
                </span>
                <span class="wf-dashboard-hero__conjunction"> for </span>
                <span class="wf-dashboard-hero__odoo">Odoo</span>
            </h2>
            <p class="wf-lead">Build, execute, and monitor business workflows — natively inside Odoo.</p>
            <p class="wf-detail-copy">
                                        Design automation flows with a visual node-based canvas, connect triggers to actions,
                                        execute in real-time, and track every run with full observability. All without leaving
                                        your Odoo environment.
            </p>
            <div class="wf-tag-row">
                <t t-foreach="navActions" t-as="nav" t-key="nav.label">
                    <button type="button" class="wf-tag" t-on-click="() => this.onNavigate(nav.xmlId)" t-esc="nav.label"/>
                </t>
            </div>
        </div>
    </t>
</templates>
