<?xml version="1.0" encoding="UTF-8"?>
<templates>
<t t-name="workflow_studio.connector_landing">
<div class="cl-page" t-ref="root">

    <!-- ══════════════════════════════════════════════════════
         HERO SECTION
    ══════════════════════════════════════════════════════ -->
    <section class="cl-hero">
        <div class="cl-hero__grid-bg"/>
        <div class="cl-hero__glow cl-hero__glow--left"/>
        <div class="cl-hero__glow cl-hero__glow--right"/>

        <div class="cl-hero__inner">
            <div class="cl-hero__eyebrow">
                <span class="cl-badge cl-badge--live">
                    <span class="cl-badge__dot"/>
                    LIVE
                </span>
                <span class="cl-hero__eyebrow-text">Case Study · Bảo Linh Commerce · Hà Nội</span>
            </div>

            <h1 class="cl-hero__headline">
                <span class="cl-hero__headline-top">Một chiều thứ Tư,</span>
                <span class="cl-hero__headline-main">
                    Bảo Linh Commerce<br/>
                    kết nối <em>mọi thứ</em>
                </span>
                <span class="cl-hero__headline-sub">Từ 8 tiếng copy-paste mỗi đêm &#x2192; 87ms automation.</span>
            </h1>

            <div class="cl-hero__ticker" t-att-class="{ 'cl-hero__ticker--fade': ui.tickerFading }">
                <span class="cl-ticker__pulse"/>
                <span class="cl-ticker__label">PROCESSING</span>
                <span class="cl-ticker__msg" t-esc="currentTickerMsg"/>
            </div>

            <div class="cl-hero__meta">
                <div class="cl-hero__meta-item">
                    <span class="cl-hero__meta-value">15.234</span>
                    <span class="cl-hero__meta-label">đơn/ngày</span>
                </div>
                <div class="cl-hero__meta-divider"/>
                <div class="cl-hero__meta-item">
                    <span class="cl-hero__meta-value">3</span>
                    <span class="cl-hero__meta-label">connectors</span>
                </div>
                <div class="cl-hero__meta-divider"/>
                <div class="cl-hero__meta-item">
                    <span class="cl-hero__meta-value">47min</span>
                    <span class="cl-hero__meta-label">setup</span>
                </div>
                <div class="cl-hero__meta-divider"/>
                <div class="cl-hero__meta-item">
                    <span class="cl-hero__meta-value">99.8%</span>
                    <span class="cl-hero__meta-label">tự động hoá</span>
                </div>
            </div>
        </div>

        <div class="cl-hero__scroll">
            <span class="cl-hero__scroll-text">Cuộn để đọc câu chuyện</span>
            <span class="cl-hero__scroll-arrow"/>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         PROBLEM — Chapter 01
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-problem" data-reveal="problem">
        <div class="cl-container">
            <div class="cl-chapter-tag">Chương 01</div>
            <h2 class="cl-section-heading">
                <span class="cl-heading-date">02.01.2025 — Thứ Năm</span>
                Ngày đơn hàng vượt tầm kiểm soát
            </h2>

            <div class="cl-problem__layout">
                <div class="cl-problem__story">
                    <p class="cl-prose cl-prose--lead">
                        Vào tháng 1, Bảo Linh Commerce — đội thương mại điện tử 12 người tại Hà Nội —
                        vừa kết thúc chiến dịch Tết và tiếp tục bán trên <strong>3 nền tảng</strong>:
                        <span class="cl-text--shopee">Shopee</span>,
                        <span class="cl-text--tiktok">TikTok Shop</span>,
                        và website Shopify của riêng họ.
                    </p>
                    <p class="cl-prose">
                        Mỗi buổi tối, ba nhân sự vận hành ngồi trước màn hình với 3 tab mở sẵn.
                        Việc của họ: copy từng đơn hàng từ seller portal của từng nền tảng vào hệ thống nội bộ,
                        kiểm tra tồn kho, tạo phiếu giao hàng thủ công. Đêm đó mất <strong>8.5 tiếng</strong>.
                    </p>

                    <div class="cl-quote cl-quote--worker">
                        <div class="cl-quote__mark">"</div>
                        <blockquote class="cl-quote__text" t-esc="story.crisis.workerQuote.text"/>
                        <cite class="cl-quote__author" t-esc="story.crisis.workerQuote.author"/>
                    </div>
                </div>

                <div class="cl-problem__pain-grid">
                    <t t-foreach="story.crisis.painPoints" t-as="p" t-key="p.label">
                        <div class="cl-pain-card">
                            <div class="cl-pain-card__icon">
                                <LucideIcon t-props="{ name: p.icon, size: 20 }"/>
                            </div>
                            <div class="cl-pain-card__value" t-esc="p.label"/>
                            <div class="cl-pain-card__sub" t-esc="p.sub"/>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         DISCOVERY — Chapter 02
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-discovery" data-reveal="discovery">
        <div class="cl-container">
            <div class="cl-chapter-tag">Chương 02</div>
            <h2 class="cl-section-heading">
                <span class="cl-heading-date">08.01.2025 — Thứ Tư</span>
                Một bài post thay đổi mọi thứ
            </h2>

            <div class="cl-discovery__layout">
                <div class="cl-discovery__post cl-card">
                    <div class="cl-post__header">
                        <div class="cl-post__avatar">SP</div>
                        <div class="cl-post__meta">
                            <span class="cl-post__group">Nhóm Shopee Seller Vietnam</span>
                            <span class="cl-post__time">08:47 sáng</span>
                        </div>
                    </div>
                    <div class="cl-post__title">
                        "Ai dùng <strong>Workflow Studio</strong> chưa? Setup 3 kênh xong trong 1 buổi chiều,
                        không cần dev. Recommend mạnh cho ae nào đang kéo đơn tay."
                    </div>
                    <div class="cl-post__footer">
                        <span class="cl-post__react">👍 247</span>
                        <span class="cl-post__react">💬 83 bình luận</span>
                        <span class="cl-post__react">↗ 412 chia sẻ</span>
                    </div>
                </div>

                <div class="cl-discovery__response">
                    <div class="cl-discovery__quote-wrapper">
                        <div class="cl-discovery__quote-line"/>
                        <blockquote class="cl-discovery__impression">
                            "Nhìn demo 5 phút là biết đây rồi."
                        </blockquote>
                        <cite class="cl-discovery__impression-author">Nguyễn Văn Bảo — CFO, Bảo Linh Commerce</cite>
                    </div>
                    <p class="cl-prose">
                        Bảo gọi họp nhóm ngay buổi chiều hôm đó. Sáng hôm sau, họ đăng ký trial.
                        Ngày 9 tháng 1, đội vận hành ngồi xuống và bắt đầu.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         SETUP TIMELINE — Chapter 03
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-setup" data-reveal="setup">
        <div class="cl-container">
            <div class="cl-chapter-tag">Chương 03</div>
            <h2 class="cl-section-heading">
                <span class="cl-heading-date">09.01.2025 — 14:12</span>
                47 phút để thay đổi cả quy trình
            </h2>

            <div class="cl-setup__layout">
                <div class="cl-timeline">
                    <div class="cl-timeline__track"/>
                    <t t-foreach="story.setup.steps" t-as="step" t-key="step.time">
                        <div class="cl-timeline__step"
                             t-att-class="{ 'cl-timeline__step--active': isStepVisible(step_index), 'cl-timeline__step--done': isStepVisible(step_index) }">
                            <div class="cl-timeline__dot"
                                 t-att-style="'--step-color:' + step.color">
                                <LucideIcon t-props="{ name: step.icon, size: 14 }"/>
                            </div>
                            <div class="cl-timeline__content">
                                <div class="cl-timeline__time" t-esc="step.time"/>
                                <div class="cl-timeline__label" t-esc="step.label"/>
                                <div class="cl-timeline__note" t-esc="step.note"/>
                            </div>
                        </div>
                    </t>
                </div>

                <div class="cl-setup__result cl-card cl-card--glow">
                    <div class="cl-setup__result-icon">
                        <LucideIcon name="CheckCircle" t-props="{ name: 'CheckCircle', size: 48 }"/>
                    </div>
                    <div class="cl-setup__result-time">14:59</div>
                    <div class="cl-setup__result-label">Production. Live.</div>
                    <div class="cl-setup__result-desc">
                        Đúng <strong>47 phút</strong> sau khi bắt đầu,
                        toàn bộ luồng đơn hàng của Bảo Linh Commerce
                        đã chạy hoàn toàn tự động.
                    </div>
                    <div class="cl-setup__stat-row">
                        <div class="cl-setup__stat">
                            <span class="cl-setup__stat-value">0</span>
                            <span class="cl-setup__stat-label">lỗi deploy</span>
                        </div>
                        <div class="cl-setup__stat">
                            <span class="cl-setup__stat-value">3</span>
                            <span class="cl-setup__stat-label">connector live</span>
                        </div>
                        <div class="cl-setup__stat">
                            <span class="cl-setup__stat-value">47<small>min</small></span>
                            <span class="cl-setup__stat-label">total setup</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         RESULTS — Animated counters
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-results" data-reveal="counters">
        <div class="cl-container">
            <div class="cl-chapter-tag">Kết quả</div>
            <h2 class="cl-section-heading">Ngày hôm sau, không có gì để làm</h2>
            <p class="cl-section-sub">
                Sáng ngày 10 tháng 1, đội vận hành đến văn phòng và lần đầu tiên
                không có gì để làm. Hệ thống đã xử lý <strong>15.234 đơn hàng</strong> trong đêm.
            </p>

            <div class="cl-counters">
                <div class="cl-counter cl-counter--main">
                    <div class="cl-counter__value">
                        <span t-esc="formatNum(counters.ordersPerDay)"/>
                    </div>
                    <div class="cl-counter__unit">đơn/ngày</div>
                    <div class="cl-counter__label">xử lý tự động hoàn toàn</div>
                </div>
                <div class="cl-counter">
                    <div class="cl-counter__value">
                        <span t-esc="counters.automationRate"/><span class="cl-counter__pct">%</span>
                    </div>
                    <div class="cl-counter__unit">automation rate</div>
                    <div class="cl-counter__label">zero manual intervention</div>
                </div>
                <div class="cl-counter">
                    <div class="cl-counter__value">
                        <span t-esc="counters.latencyMs"/><span class="cl-counter__unit-inline">ms</span>
                    </div>
                    <div class="cl-counter__unit">avg latency</div>
                    <div class="cl-counter__label">end-to-end per order</div>
                </div>
                <div class="cl-counter">
                    <div class="cl-counter__value" t-esc="counters.staffFreed"/>
                    <div class="cl-counter__unit">nhân sự</div>
                    <div class="cl-counter__label">freed for meaningful work</div>
                </div>
            </div>

            <div class="cl-results__morning-quote cl-card" data-reveal="morning-quote">
                <div class="cl-quote__mark cl-quote__mark--large">"</div>
                <blockquote class="cl-results__quote-text" t-esc="story.results.firstMorningQuote.text"/>
                <cite class="cl-results__quote-author" t-esc="story.results.firstMorningQuote.author"/>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         FLOW DIAGRAM — Animated SVG
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-flow-section" data-reveal="flow">
        <div class="cl-container cl-container--wide">
            <div class="cl-chapter-tag">Architecture</div>
            <h2 class="cl-section-heading">Luồng dữ liệu thời gian thực</h2>

            <div class="cl-flow-diagram">
                <!-- Source labels -->
                <div class="cl-flow__sources">
                    <div class="cl-flow__source-node" style="--node-color:#EE4D2D">
                        <span class="cl-flow__node-emoji">🛍️</span>
                        <span class="cl-flow__node-name">Shopee</span>
                        <span class="cl-flow__node-stat">8.421 đơn/h</span>
                    </div>
                    <div class="cl-flow__source-node" style="--node-color:#69C9D0">
                        <span class="cl-flow__node-emoji">🎵</span>
                        <span class="cl-flow__node-name">TikTok Shop</span>
                        <span class="cl-flow__node-stat">4.823 đơn/h</span>
                    </div>
                    <div class="cl-flow__source-node" style="--node-color:#96BF48">
                        <span class="cl-flow__node-emoji">🌐</span>
                        <span class="cl-flow__node-name">Shopify</span>
                        <span class="cl-flow__node-stat">1.990 đơn/h</span>
                    </div>
                </div>

                <!-- SVG animated flow lines -->
                <div class="cl-flow__svg-wrapper">
                    <svg class="cl-flow__svg" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid meet">
                        <!-- Input lines -->
                        <path class="cl-flow__path cl-flow__path--rail" d="M 0,42 L 200,42"/>
                        <path class="cl-flow__path cl-flow__path--rail" d="M 0,100 L 200,100"/>
                        <path class="cl-flow__path cl-flow__path--rail" d="M 0,158 L 200,158"/>
                        <!-- Animated flows -->
                        <path class="cl-flow__path cl-flow__path--active cl-flow__path--delay0" d="M 0,42 L 200,42"/>
                        <path class="cl-flow__path cl-flow__path--active cl-flow__path--delay1" d="M 0,100 L 200,100"/>
                        <path class="cl-flow__path cl-flow__path--active cl-flow__path--delay2" d="M 0,158 L 200,158"/>
                        <!-- Dots -->
                        <circle class="cl-flow__dot cl-flow__dot--delay0" r="3" fill="#00D8FF">
                            <animateMotion dur="1.8s" repeatCount="indefinite" begin="0s">
                                <mpath href="#cl-path-1"/>
                            </animateMotion>
                        </circle>
                        <circle class="cl-flow__dot cl-flow__dot--delay1" r="3" fill="#00D8FF">
                            <animateMotion dur="1.8s" repeatCount="indefinite" begin="0.6s">
                                <mpath href="#cl-path-2"/>
                            </animateMotion>
                        </circle>
                        <circle class="cl-flow__dot cl-flow__dot--delay2" r="3" fill="#00D8FF">
                            <animateMotion dur="1.8s" repeatCount="indefinite" begin="1.2s">
                                <mpath href="#cl-path-3"/>
                            </animateMotion>
                        </circle>
                        <!-- Hidden paths for animateMotion -->
                        <path id="cl-path-1" d="M 0,42 L 200,42" style="display:none"/>
                        <path id="cl-path-2" d="M 0,100 L 200,100" style="display:none"/>
                        <path id="cl-path-3" d="M 0,158 L 200,158" style="display:none"/>
                    </svg>
                </div>

                <!-- Engine -->
                <div class="cl-flow__engine cl-card cl-card--engine">
                    <div class="cl-flow__engine-pulse"/>
                    <div class="cl-flow__engine-icon">
                        <LucideIcon name="Workflow" t-props="{ name: 'Workflow', size: 28 }"/>
                    </div>
                    <div class="cl-flow__engine-name">Workflow Studio</div>
                    <div class="cl-flow__engine-stats">
                        <span class="cl-flow__engine-stat">
                            <span class="cl-dot cl-dot--green"/>
                            87ms avg
                        </span>
                        <span class="cl-flow__engine-stat">
                            <span class="cl-dot cl-dot--cyan"/>
                            99.8% uptime
                        </span>
                    </div>
                </div>

                <!-- SVG output side -->
                <div class="cl-flow__svg-wrapper">
                    <svg class="cl-flow__svg" viewBox="0 0 200 200" preserveAspectRatio="xMidYMid meet">
                        <path class="cl-flow__path cl-flow__path--rail" d="M 0,70 L 200,70"/>
                        <path class="cl-flow__path cl-flow__path--rail" d="M 0,130 L 200,130"/>
                        <path class="cl-flow__path cl-flow__path--active cl-flow__path--delay0" d="M 0,70 L 200,70"/>
                        <path class="cl-flow__path cl-flow__path--active cl-flow__path--delay1" d="M 0,130 L 200,130"/>
                        <circle r="3" fill="#10B981">
                            <animateMotion dur="1.6s" repeatCount="indefinite" begin="0.2s">
                                <mpath href="#cl-out-path-1"/>
                            </animateMotion>
                        </circle>
                        <circle r="3" fill="#10B981">
                            <animateMotion dur="1.6s" repeatCount="indefinite" begin="1s">
                                <mpath href="#cl-out-path-2"/>
                            </animateMotion>
                        </circle>
                        <path id="cl-out-path-1" d="M 0,70 L 200,70" style="display:none"/>
                        <path id="cl-out-path-2" d="M 0,130 L 200,130" style="display:none"/>
                    </svg>
                </div>

                <!-- Output labels -->
                <div class="cl-flow__outputs">
                    <div class="cl-flow__output-node" style="--node-color:#F44336">
                        <span class="cl-flow__node-emoji">📦</span>
                        <span class="cl-flow__node-name">GHN</span>
                        <span class="cl-flow__node-stat">42ms</span>
                    </div>
                    <div class="cl-flow__output-node" style="--node-color:#FF6B35">
                        <span class="cl-flow__node-emoji">🚚</span>
                        <span class="cl-flow__node-name">GHTK</span>
                        <span class="cl-flow__node-stat">67ms</span>
                    </div>
                    <div class="cl-flow__output-node cl-flow__output-node--secondary" style="--node-color:#4B5563">
                        <span class="cl-flow__node-emoji">📊</span>
                        <span class="cl-flow__node-name">Odoo ERP</span>
                        <span class="cl-flow__node-stat">sync</span>
                    </div>
                </div>
            </div>

            <!-- Flow legend -->
            <div class="cl-flow__legend">
                <div class="cl-flow__legend-item">
                    <div class="cl-flow__legend-line cl-flow__legend-line--cyan"/>
                    <span>Input: đơn hàng đến</span>
                </div>
                <div class="cl-flow__legend-item">
                    <div class="cl-flow__legend-line cl-flow__legend-line--green"/>
                    <span>Output: fulfillment &amp; sync</span>
                </div>
                <div class="cl-flow__legend-item">
                    <span class="cl-dot cl-dot--pulse"/>
                    <span>Real-time processing</span>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         CONNECTORS GALLERY
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-connectors-section" data-reveal="connectors">
        <div class="cl-container">
            <div class="cl-chapter-tag">Integrations</div>
            <h2 class="cl-section-heading">Các connector đang hoạt động</h2>

            <div class="cl-connectors__grid">
                <t t-foreach="activeConnectors" t-as="c" t-key="c.name">
                    <div class="cl-connector-card cl-card"
                         t-att-style="'--conn-color:' + c.color + ';--conn-bg:' + c.bg">
                        <div class="cl-connector-card__emoji" t-esc="c.emoji"/>
                        <div class="cl-connector-card__info">
                            <div class="cl-connector-card__name" t-esc="c.name"/>
                            <div class="cl-connector-card__category" t-esc="c.category"/>
                        </div>
                        <div class="cl-connector-card__stat" t-esc="c.stat"/>
                        <div class="cl-connector-card__status">
                            <span class="cl-dot cl-dot--green"/>
                            Live
                        </div>
                    </div>
                </t>
            </div>

            <div class="cl-connectors__coming">
                <div class="cl-connectors__coming-label">Sắp ra mắt</div>
                <div class="cl-connectors__coming-list">
                    <t t-foreach="comingConnectors" t-as="c" t-key="c.name">
                        <div class="cl-connector-chip">
                            <span t-esc="c.emoji"/>
                            <span t-esc="c.name"/>
                            <span class="cl-connector-chip__eta" t-esc="c.note"/>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         FEATURES GRID
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-features-section" data-reveal="features">
        <div class="cl-container">
            <div class="cl-chapter-tag">Capabilities</div>
            <h2 class="cl-section-heading">Production-grade từ ngày đầu tiên</h2>
            <p class="cl-section-sub">
                Không phải prototype. Không phải poc. Workflow Studio được thiết kế để xử lý
                lưu lượng thực sự — với đầy đủ tooling cho throughput cao, lỗi có thể trace,
                và quy trình thay đổi không cần downtime.
            </p>

            <div class="cl-features__grid">
                <t t-foreach="story.features" t-as="f" t-key="f.title">
                    <div class="cl-feature-card cl-card">
                        <div class="cl-feature-card__icon">
                            <LucideIcon t-props="{ name: f.icon, size: 22 }"/>
                        </div>
                        <div class="cl-feature-card__title" t-esc="f.title"/>
                        <div class="cl-feature-card__desc" t-esc="f.desc"/>
                    </div>
                </t>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         TESTIMONIAL
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-testimonial-section" data-reveal="testimonial">
        <div class="cl-container cl-container--narrow">
            <div class="cl-testimonial cl-card">
                <div class="cl-testimonial__quote-mark">"</div>
                <blockquote class="cl-testimonial__text" t-esc="story.testimonial.quote"/>
                <div class="cl-testimonial__footer">
                    <div class="cl-testimonial__avatar" t-esc="story.testimonial.avatar"/>
                    <div class="cl-testimonial__author-info">
                        <div class="cl-testimonial__author" t-esc="story.testimonial.author"/>
                        <div class="cl-testimonial__title" t-esc="story.testimonial.title"/>
                    </div>
                    <div class="cl-testimonial__metric">
                        <div class="cl-testimonial__metric-value" t-esc="story.testimonial.metric"/>
                        <div class="cl-testimonial__metric-label" t-esc="story.testimonial.metricLabel"/>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════════════════════════════════════════════════════
         CTA
    ══════════════════════════════════════════════════════ -->
    <section class="cl-section cl-cta-section" data-reveal="cta">
        <div class="cl-cta-glow"/>
        <div class="cl-container cl-container--narrow">
            <div class="cl-cta">
