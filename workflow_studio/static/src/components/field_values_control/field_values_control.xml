<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="workflow_studio.field_values_control">
        <div class="o_workflow_field_values">
            <div class="ncp-table-shell ncp-table-shell--pair fv-table">
                <div class="ncp-table-shell__header">
                    <div class="ncp-table-shell__heading">Field</div>
                    <div class="ncp-table-shell__heading">Value</div>
                    <div class="ncp-table-shell__heading">Actions</div>
                </div>
                <t t-foreach="state.rows" t-as="row" t-key="row.id">
                    <div class="ncp-table-shell__row fv-row" t-att-class="{ 'ncp-table-shell__row--placeholder': !row.field and !row.value }">
                        <div class="ncp-table-shell__cell fv-field-cell">
                            <ExpressionInput
                                label="''"
                                value="row.field"
                                placeholder="field_name"
                                mode="getFieldMode(row.id)"
                                toggleMode="'side'"
                                suggestions="state.fieldSuggestions"
                                onModeChange="(m) => this.onFieldModeChange(row.id, m)"
                                onChange="(v) => this.onFieldChange(row_index, v)"
                                onDrop="(payload) => this.onFieldDrop(row.id, payload)"
                                readonly="props.readonly"
                            />
                        </div>
                        <div class="ncp-table-shell__cell fv-value-cell">
                            <ExpressionInput
                                label="''"
                                value="row.value"
                                placeholder="'value or {{ expression }}'"
                                context="props.inputContext"
                                mode="getValueMode(row.id)"
                                toggleMode="'side'"
                                onModeChange="(m) => this.onValueModeChange(row.id, m)"
                                onChange="(v) => this.onValueChange(row_index, v)"
                                readonly="props.readonly"
                            />
                        </div>
                        <div class="ncp-table-shell__actions fv-actions">
                            <button
                                t-if="!props.readonly"
                                class="kv-remove fv-remove"
                                t-on-click="() => this.removeRow(row_index)"
                                type="button"
                                title="Remove field"
                            ><i class="fa fa-trash"/></button>
                        </div>
                    </div>
                </t>
            </div>
            <button
                t-if="!props.readonly"
                class="kv-add fv-add"
                t-on-click="addRow"
                type="button"
            >+ Add Field</button>
        </div>
    </t>
</templates>
