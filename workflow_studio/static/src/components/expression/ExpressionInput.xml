<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="workflow_studio.expression_input">
		<div class="expression-input" t-att-class="{
				 'expression-mode': isExpression,
				 'focused': state.isFocused,
				 'drag-over': state.isDragOver,
				 'expression-readonly': props.readonly,
				 'expression-input--side-toggle': showSideToggle,
				 'expression-input--side-toggle-active': showSideToggle and isExpression
			 }">
			<!-- Header with label and toggle -->
			<div t-if="showHeader" class="expression-input__header">
				<label t-if="props.label" class="expression-input__label">
					<t t-esc="props.label"/>
				</label>
				<!-- Fixed/Expression Toggle (n8n style) -->
				<div t-if="showTopToggle" class="expression-input__mode-toggle">
					<button type="button" class="mode-btn" t-att-class="{ active: !isExpression }" t-on-click="onClickFixed" title="Fixed value">
						Fixed
					</button>
					<button type="button" class="mode-btn mode-btn--expression" t-att-class="{ active: isExpression }" t-on-click="onClickExpression" title="Dynamic expression">
						Expression
					</button>
				</div>
			</div>
			<!-- Input field -->
			<Dropdown manual="true" state="suggestionsDropdownState" menuClass="'expression-input__suggestions-menu'" position="'bottom-start'" menuRef="dropdownMenuRef">
				<div class="expression-input__field" t-ref="fieldRef" t-on-dragenter="onDragEnter" t-on-dragleave="onDragLeave" t-on-dragover="onDragOver" t-on-drop="onDrop">
					<button t-if="showSideToggle" type="button" class="expression-input__side-toggle" t-att-class="{ active: isExpression }" t-att-title="isExpression ? 'Switch to fixed value' : 'Switch to dynamic expression'" t-on-click="onClickSideToggle">
						<span class="expression-input__side-toggle-label">ƒx</span>
					</button>
					<!-- Expression mode prefix -->
					<span t-if="isExpression and !showSideToggle" class="expression-input__fx">ƒx</span>
					<div class="expression-input__input-layer" t-att-class="{ 'has-highlight': hasExpressionHighlights, 'expression-input__input-layer--singleline': !props.multiline }">
						<div t-if="hasExpressionHighlights" class="expression-input__highlights">
							<div class="expression-input__highlights-content" t-att-style="highlightContentStyle">
								<t t-foreach="highlightSegments" t-as="segment" t-key="segment.id">
									<span class="expression-input__highlight-fragment" t-att-class="{ 'expression-input__highlight': segment.isExpression}" t-esc="segment.text" />
								</t>
							</div>
						</div>
						<input t-if="!props.multiline" type="text" class="expression-input__text" t-att-class="{ 'text-dark': isExpression }" t-att-value="currentValue" t-att-placeholder="isExpression ? '{{ _json.field }}' : (props.placeholder || 'Enter value...')" t-on-input="onInput" t-on-focus="onFocus" t-on-blur="onBlur" t-on-keydown="onKeyDown" t-on-scroll="onScroll" spellcheck="false" autocomplete="off" t-att-disabled="props.readonly ? 'disabled' : undefined"/>
						<textarea t-else="" class="expression-input__textarea" t-att-class="{ 'text-dark': isExpression }" t-att-value="currentValue" t-att-rows="textAreaRows" t-att-placeholder="isExpression ? '{{ _json.field }}' : (props.placeholder || 'Enter value...')" t-on-input="onInput" t-on-focus="onFocus" t-on-blur="onBlur" t-on-keydown="onKeyDown" t-on-scroll="onScroll" spellcheck="false" t-att-disabled="props.readonly ? 'disabled' : undefined"/>
					</div>
					<!-- Drop indicator -->
					<div t-if="state.isDragOver" class="expression-input__drop-indicator">
						<i class="fa fa-plus-circle"/>
						Drop to insert

					</div>
				</div>
				<t t-set-slot="content">
					<div t-if="shouldShowSuggestions" class="expression-input__suggestions" t-on-pointerdown="onSuggestionsPointerDown">
						<DropdownItem t-foreach="filteredSuggestions" t-as="item" t-key="item.value + ':' + item_index" class="{ 'expression-input__suggestion-item': true, active: item_index === state.activeSuggestionIndex }" attrs="getSuggestionItemAttrs(item_index)" onSelected="() => this.onSuggestionSelected(item)">
							<span class="suggestion-label" t-esc="item.label"/>
							<span t-if="item.description" class="suggestion-description" t-esc="item.description"/>
						</DropdownItem>
					</div>
				</t>
			</Dropdown>
			<!-- Result Preview (expression mode only) -->
			<div t-if="isExpression" class="expression-input__result">
				<div class="result-value">
					<span t-if="previewType" class="result-type-badge badge text-bg-info me-1" t-esc="previewType"/>
					<t t-if="previewResult and !previewResult.error">
						<t t-esc="previewDisplay"/>
					</t>
					<t t-elif="previewResult and previewResult.error">
						<span class="error">
							<t t-esc="previewDisplay"/>
						</span>
					</t>
					<t t-else="">
						<span class="empty">[Execute previous nodes for preview]</span>
					</t>
				</div>
			</div>
		</div>
	</t>
</templates>
