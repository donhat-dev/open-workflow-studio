<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="workflow_studio.WorkflowHistoryPanel">
        <div class="workflow-history-panel">
            <div class="workflow-history-panel__header d-flex align-items-center justify-content-between px-3 py-2 border-bottom">
                <div class="workflow-history-panel__title d-flex align-items-center gap-2 fw-semibold">
                    <i class="fa fa-history"/>
                    <span>History</span>
                </div>
                <button class="btn btn-light d-inline-flex" t-on-click="props.onClose" title="Close">
                    <i class="fa fa-times"/>
                </button>
            </div>

            <!-- Tab Switcher -->
            <div class="history-panel-tabs d-flex border-bottom">
                <button class="history-panel-tab" t-att-class="{ active: state.activeTab === 'versions' }" t-on-click="() => this.switchTab('versions')" type="button">
                    <i class="fa fa-code-fork me-1"/>Versions
                </button>
                <button class="history-panel-tab" t-att-class="{ active: state.activeTab === 'runs' }" t-on-click="() => this.switchTab('runs')" type="button">
                    <i class="fa fa-play-circle me-1"/>Runs
                </button>
            </div>

            <!-- ================== VERSIONS TAB ================== -->
            <t t-if="state.activeTab === 'versions'">
                <div class="workflow-history-panel__toolbar d-flex align-items-center justify-content-between px-3 py-2">
                    <div class="history-toolbar__info">
                        <div class="history-toolbar__label small text-muted">Preview</div>
                        <t t-if="state.selectedRevisionId">
                            <div class="history-toolbar__value fw-semibold">
                                <t t-if="isCurrentSelected">Current version</t>
                                <t t-else="">Version v<t t-esc="state.selectedRevisionId"/></t>
                            </div>
                            <div class="history-toolbar__meta">
                                <span class="history-toolbar__tag badge text-bg-light">Read-only</span>
                                <t t-if="state.previewing">
                                    <span class="history-toolbar__status small text-muted">Loading\u2026</span>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="history-toolbar__value text-muted">Select a version to preview</div>
                            <div class="history-toolbar__meta">
                                <span class="history-toolbar__tag badge text-bg-light">Read-only</span>
                            </div>
                        </t>
                    </div>
                    <button
                        class="btn btn-primary btn-sm history-restore-btn"
                        t-on-click="onRestoreClick"
                        t-att-disabled="!canRestore ? 'disabled' : undefined">
                        <i class="fa fa-undo me-1"/>Restore
                    </button>
                </div>

                <div class="workflow-history-panel__body">
                    <t t-if="state.loading">
                        <div class="history-empty text-muted small text-center py-4">Loading history...</div>
                    </t>
                    <t t-elif="!displayRevisions.length">
                        <div class="history-empty text-muted small text-center py-4">No version history available</div>
                    </t>
                    <t t-else="">
                        <div class="history-timeline">
                            <t t-foreach="groupedRevisions" t-as="group" t-key="group.label">
                                <div class="history-group">
                                    <div class="history-group__label text-uppercase small text-muted fw-semibold">
                                        <t t-esc="group.label"/>
                                    </div>
                                    <div class="history-group__items">
                                        <t t-foreach="group.revisions" t-as="revision" t-key="revision.revision_id">
                                            <button
                                                t-attf-class="history-item {{ state.selectedRevisionId === revision.revision_id ? 'active' : '' }}"
                                                t-on-click="() => this.onRevisionClick(revision.revision_id)">
                                                
                                                <!-- Timeline Visuals -->
                                                <div class="history-item__timeline-col">
                                                    <div class="history-item__line_top"/>
                                                    <div class="history-item__dot">
                                                        <t t-if="state.selectedRevisionId === revision.revision_id">
                                                            <i class="fa fa-play history-item__dot-icon"/>
                                                        </t>
                                                    </div>
                                                    <div class="history-item__line_bottom"/>
                                                </div>

                                                <div class="history-item__card">
                                                    <div class="history-item__header">
                                                        <div class="history-item__info">
                                                            <time class="history-item__time" t-att-title="formatDate(revision.create_date)">
                                                                <t t-esc="revision.readableTime"/>
                                                            </time>
                                                            <div class="history-item__author">
                                                                <small>by
                                                                    <t t-if="revision.is_current"> You</t>
                                                                    <t t-else=""> <t t-esc="revision.create_user_name"/></t>
                                                                </small>
                                                            </div>
                                                        </div>
                                                        <div class="history-item__avatar-wrap">
                                                            <t t-if="revision.avatarUrl">
                                                                <img t-att-src="revision.avatarUrl" class="history-item__avatar" alt="User"/>
                                                            </t>
                                                            <t t-else="">
                                                                <span class="history-item__avatar history-item__avatar--placeholder"/>
                                                            </t>
                                                        </div>
                                                    </div>

                                                    <div class="history-item__main">
                                                        <span class="history-item__title">v<t t-esc="revision.revision_id"/></span>
                                                    </div>

                                                    <div class="history-item__badges">
                                                        <t t-if="revision.is_current">
                                                            <span class="history-badge history-badge--current">Active</span>
                                                        </t>
                                                        <t t-elif="revision.is_milestone">
                                                            <span class="history-badge history-badge--milestone">Milestone</span>
                                                        </t>
                                                        <t t-elif="revision.type and revision.type !== 'snapshot'">
                                                            <span class="history-badge"><t t-esc="revision.type"/></span>
                                                        </t>
                                                    </div>

                                                    <t t-if="revision.note">
                                                        <div class="history-item__note">
                                                            <t t-esc="revision.note"/>
                                                        </div>
                                                    </t>
                                                </div>
                                            </button>
                                        </t>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </t>
                </div>
            </t>

            <!-- ================== RUNS TAB ================== -->
            <t t-if="state.activeTab === 'runs'">
                <div class="workflow-history-panel__toolbar d-flex align-items-center justify-content-between px-3 py-2">
                    <div class="history-toolbar__info">
                        <t t-if="isRunSelected">
                            <t t-set="selectedRun" t-value="getSelectedRun()"/>
                            <div class="history-toolbar__label small text-muted">Viewing Run</div>
                            <div class="history-toolbar__value fw-semibold" t-esc="selectedRun and selectedRun.name or ''"/>
                            <div class="history-toolbar__meta">
                                <span class="history-toolbar__tag badge text-bg-light">Read-only</span>
                                <t t-if="selectedRun">
                                    <span t-attf-class="history-toolbar__tag run-status-badge {{ getRunStatusClass(selectedRun.status) }}">
                                        <i t-att-class="getRunStatusIcon(selectedRun.status)"/>
                                        <t t-esc="selectedRun.status"/>
                                    </span>
                                    <span t-attf-class="history-toolbar__tag run-mode-badge {{ getRunModeClass(selectedRun.execution_mode) }}">
                                        <t t-esc="getRunModeLabel(selectedRun.execution_mode)"/>
                                    </span>
                                    <t t-if="selectedRun.queue_job_state">
                                        <span t-attf-class="history-toolbar__tag run-queue-badge {{ getQueueStateClass(selectedRun.queue_job_state) }}">
                                            <t t-esc="getQueueStateLabel(selectedRun.queue_job_state)"/>
                                        </span>
                                    </t>
                                </t>
                            </div>
                        </t>
                        <t t-else="">
                            <div class="history-toolbar__label small text-muted">Execution Runs</div>
                            <div class="history-toolbar__value text-muted">Select a run to view</div>
                        </t>
                    </div>
                    <t t-if="isRunSelected">
                        <div class="d-flex align-items-center gap-2">
                            <button
                                t-if="canCancelSelectedRun"
                                class="btn btn-outline-danger btn-sm"
                                t-on-click="onCancelRun"
                                type="button">
                                <i class="fa fa-ban me-1"/>Cancel
                            </button>
                            <button class="btn btn-outline-secondary btn-sm" t-on-click="exitRunView" type="button">
                                <i class="fa fa-arrow-left me-1"/>Back
                            </button>
                        </div>
                    </t>
                    <t t-else="">
                        <button class="btn btn-outline-secondary btn-sm" t-on-click="loadRuns" t-att-disabled="state.loadingRuns ? 'disabled' : undefined" type="button">
                            <i class="fa fa-refresh me-1"/>Refresh
                        </button>
                    </t>
                </div>

                <div class="workflow-history-panel__body">
                    <t t-if="state.loadingRuns">
                        <div class="history-empty text-muted small text-center py-4">Loading runs...</div>
                    </t>
                    <t t-elif="!state.runs.length">
                        <div class="history-empty text-muted small text-center py-4">
                            <i class="fa fa-play-circle fa-2x mb-2 d-block"/>
                            No execution runs yet
                        </div>
                    </t>
                    <t t-else="">
                        <div class="runs-list">
                            <t t-foreach="state.runs" t-as="run" t-key="run.id">
                                <button
                                    t-attf-class="run-item {{ state.selectedRunId === run.id ? 'active' : '' }}"
                                    t-on-click="() => this.selectRun(run.id)">
                                    <div class="run-item__header">
                                        <div class="run-item__name" t-esc="run.name"/>
                                        <span t-attf-class="run-item__status {{ getRunStatusClass(run.status) }}">
                                            <i t-att-class="getRunStatusIcon(run.status)"/>
                                        </span>
                                    </div>
                                    <div class="run-item__meta">
                                        <span class="run-item__time" t-esc="formatDate(run.started_at)"/>
                                    </div>
                                    <div class="run-item__badges">
                                        <span t-attf-class="run-mode-badge {{ getRunModeClass(run.execution_mode) }}">
                                            <t t-esc="getRunModeLabel(run.execution_mode)"/>
                                        </span>
                                        <t t-if="run.queue_job_state">
                                            <span t-attf-class="run-queue-badge {{ getQueueStateClass(run.queue_job_state) }}">
                                                <t t-esc="getQueueStateLabel(run.queue_job_state)"/>
                                            </span>
                                        </t>
                                    </div>
                                    <div class="run-item__details">
                                        <span class="run-item__duration">
                                            <i class="fa fa-clock-o me-1"/>
                                            <t t-esc="formatDuration(run.duration_seconds)"/>
                                        </span>
                                        <span class="run-item__nodes" t-if="run.node_count_executed">
                                            <i class="fa fa-cube me-1"/>
                                            <t t-esc="run.node_count_executed"/> nodes
                                        </span>
                                    </div>
                                    <t t-if="run.error_message">
                                        <div class="run-item__error" t-esc="run.error_message"/>
                                    </t>
                                </button>
                            </t>
                        </div>
                    </t>
                </div>
            </t>
        </div>
    </t>
</templates>
