<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="workflow_studio.control_renderer">
		<div class="control-renderer" t-att-class="'control-type-' + controlType + (props.readonly ? ' control-readonly' : '')">
			<!-- LABEL -->
			<label t-if="label" class="control-label" t-esc="label"/>
			<!-- TEXT INPUT -->
			<t t-if="controlType === 'text' or controlType === 'expression'">
				<ExpressionInput value="value" placeholder="placeholder" context="props.inputContext" multiline="isMultiline" mode="props.mode" suggestions="suggestions" valueSuggestions="valueSuggestions" expressionSuggestions="expressionSuggestions" onModeChange="(m) => this.onExpressionModeChange(m)" onChange="(v) => this.onExpressionChange(v)" readonly="props.readonly"/>
			</t>
			<!-- SELECT -->
			<t t-elif="controlType === 'select'">
				<select class="control-select" t-on-change="onSelectChange" t-att-disabled="props.readonly ? 'disabled' : undefined">
					<t t-foreach="options" t-as="opt" t-key="opt.value">
						<option t-att-value="opt.value" t-att-selected="opt.value === value" t-esc="opt.label" />
					</t>
				</select>
			</t>
			<!-- NUMBER -->
			<t t-elif="controlType === 'number'">
				<input type="number" class="control-input control-number" t-att-value="value" t-att-min="props.control.min" t-att-max="props.control.max" t-att-step="props.control.step" t-on-input="onInput" t-att-disabled="props.readonly ? 'disabled' : undefined"/>
			</t>
			<!-- CHECKBOX -->
			<t t-elif="controlType === 'checkbox'">
				<input type="checkbox" class="control-checkbox" t-att-checked="value" t-on-change="onCheckboxChange" t-att-disabled="props.readonly ? 'disabled' : undefined"/>
			</t>
			<!-- KEY-VALUE PAIRS -->
			<t t-elif="controlType === 'keyvalue'">
				<div class="control-keyvalue">
					<t t-foreach="pairs" t-as="pair" t-key="pair.id">
						<div class="kv-row kv-row--stack">
							<div class="kv-row__meta d-flex align-items-center justify-content-between">
								<span class="kv-field-label">Name</span>
								<button class="kv-remove" t-on-click="() => this.removePair(pair_index)" t-att-disabled="pairs.length &lt;= 1 or props.readonly">×</button>
							</div>
							<div class="kv-key-cell">
								<ExpressionInput value="pair.key" placeholder="props.control.keyPlaceholder" context="props.inputContext" mode="this.getPairKeyMode(pair.id)" suggestions="suggestions" valueSuggestions="suggestions" expressionSuggestions="expressionSuggestions" onModeChange="(m) => this.onPairKeyModeChange(pair.id, m)" onChange="(v) => this.onKeyChange(pair_index, v)" readonly="props.readonly"/>
							</div>
							<span class="kv-field-label">Value</span>
							<div class="kv-value-cell">
								<ExpressionInput value="pair.value" placeholder="props.control.valuePlaceholder" context="props.inputContext" mode="this.getPairValueMode(pair.id)" suggestions="getPairValueSuggestions(pair)" valueSuggestions="getPairValueSuggestions(pair)" expressionSuggestions="expressionSuggestions" onModeChange="(m) => this.onPairValueModeChange(pair.id, m)" onChange="(v) => this.onValueExpressionChange(pair_index, v)" readonly="props.readonly"/>
							</div>
						</div>
					</t>
					<button t-if="!props.readonly" class="kv-add" t-on-click="addPair">Add Parameter</button>
				</div>
			</t>
			<!-- CODE EDITOR (Monaco) -->
			<t t-elif="controlType === 'code'">
				<CodeEditor
					value="value"
					height="props.control.height || 200"
					language="props.control.language || 'python'"
					placeholder="props.control.placeholder || ''"
					completionContext="props.inputContext"
					onChange="(v) => this.onCodeChange(v)"
					readonly="props.readonly"
				/>
			</t>
			<!-- AUTH CONTROL (composite) -->
			<t t-elif="controlType === 'auth'">
				<AuthControl
					value="value"
					onChange.bind="onAuthChange"
					inputContext="props.inputContext"
					suggestionsByKey="suggestionsByKey"
					readonly="props.readonly"
				/>
			</t>
			<!-- BODY TYPE CONTROL (composite) -->
			<t t-elif="controlType === 'body_type'">
				<BodyTypeControl
					value="value"
					onChange.bind="onBodyTypeChange"
					inputContext="props.inputContext"
					suggestionsByKey="suggestionsByKey"
					readonly="props.readonly"
				/>
			</t>
			<!-- QUERY PARAMS CONTROL -->
			<t t-elif="controlType === 'query_params'">
				<QueryParamsControl
					value="value"
					onChange.bind="onQueryParamsChange"
					inputContext="props.inputContext"
					suggestionsByKey="suggestionsByKey"
					readonly="props.readonly"
				/>
			</t>
			<!-- MODEL SELECT — ExpressionInput fixed mode with Odoo model autocomplete -->
			<t t-elif="controlType === 'model_select'">
				<ExpressionInput
					value="value"
					placeholder="placeholder"
					mode="'fixed'"
					toggleMode="'none'"
					suggestions="suggestions"
					valueSuggestions="valueSuggestions"
					onChange="(v) => this.onExpressionChange(v)"
					readonly="props.readonly"
				/>
				<div class="control-description">Literal model name only. Expressions are not supported here.</div>
			</t>
			<!-- DOMAIN — Odoo DomainSelector (field-aware, type-safe operators) -->
			<t t-elif="controlType === 'domain'">
				<DomainControl
					resModel="resModel"
					value="value"
					onChange="(v) => this.onExpressionChange(v)"
					readonly="props.readonly"
					inputContext="props.inputContext"
				/>
			</t>
			<!-- FIELD VALUES — visual field→value rows for create/write ops -->
			<t t-elif="controlType === 'field_values'">
				<FieldValuesControl
					resModel="resModel"
					operation="operation"
					value="value"
					onChange="(v) => this.onExpressionChange(v)"
					readonly="props.readonly"
					inputContext="props.inputContext"
				/>
			</t>
			<!-- TRIGGER FIELDS — model-aware checkbox grid for record-event triggers -->
			<t t-elif="controlType === 'trigger_fields'">
				<TriggerFieldsControl
					value="value"
					suggestions="suggestions"
					onChange.bind="onTriggerFieldsChange"
					readonly="props.readonly"
				/>
			</t>
		</div>
	</t>
</templates>
