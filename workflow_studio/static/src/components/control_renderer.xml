<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="workflow_studio.control_renderer">
		<div class="control-renderer" t-att-class="'control-type-' + controlType + (props.readonly ? ' control-readonly' : '')">
			<!-- LABEL (non-expression controls only; expression controls delegate label into ExpressionInput header) -->
			<label t-if="label and controlType !== 'text' and controlType !== 'expression'" class="control-label" t-esc="label"/>
			<!-- TEXT INPUT -->
			<t t-if="controlType === 'text' or controlType === 'expression'">
				<ExpressionInput value="value" placeholder="placeholder" label="label" context="props.inputContext" multiline="isMultiline" mode="props.mode" toggleMode="'side'" suggestions="suggestions" valueSuggestions="valueSuggestions" expressionSuggestions="expressionSuggestions" onModeChange="(m) => this.onExpressionModeChange(m)" onChange="(v) => this.onExpressionChange(v)" readonly="isReadonly"/>
			</t>
			<!-- SELECT -->
			<t t-elif="controlType === 'select'">
				<select class="control-select" t-on-change="onSelectChange" t-att-disabled="isReadonly ? 'disabled' : undefined">
					<t t-foreach="options" t-as="opt" t-key="opt.value">
						<option t-att-value="opt.value" t-att-selected="opt.value === value" t-esc="opt.label" />
					</t>
				</select>
			</t>
			<!-- NUMBER -->
			<t t-elif="controlType === 'number'">
				<input type="number" class="control-input control-number" t-att-value="value" t-att-min="props.control.min" t-att-max="props.control.max" t-att-step="props.control.step" t-on-input="onInput" t-att-disabled="isReadonly ? 'disabled' : undefined"/>
			</t>
			<!-- CHECKBOX -->
			<t t-elif="controlType === 'checkbox'">
				<input type="checkbox" class="control-checkbox" t-att-checked="value" t-on-change="onCheckboxChange" t-att-disabled="isReadonly ? 'disabled' : undefined"/>
			</t>
			<!-- KEY-VALUE PAIRS -->
			<t t-elif="controlType === 'keyvalue'">
				<div class="control-keyvalue">
					<KeyValueTable
						pairs="value"
						withToggle="props.control.key === 'headers'"
						onChange.bind="onKeyValueChange"
						inputContext="props.inputContext"
						keyPlaceholder="props.control.keyPlaceholder"
						valuePlaceholder="props.control.valuePlaceholder"
						keySuggestions="suggestions"
						valueSuggestions="valueSuggestions"
						expressionSuggestions="expressionSuggestions"
						suggestionsByKey="suggestionsByKey"
						lockedKeys="lockedKeys"
						pairModes="props.pairModes"
						onPairModeChange="onKeyValuePairModeChange"
						readonly="isReadonly"
					/>
				</div>
			</t>
			<!-- CODE EDITOR (Monaco) -->
			<t t-elif="controlType === 'code'">
				<CodeEditor
					value="value"
					height="props.control.height || 200"
					language="props.control.language || 'python'"
					placeholder="props.control.placeholder || ''"
					completionContext="props.inputContext"
					onChange="(v) => this.onCodeChange(v)"
					readonly="isReadonly"
				/>
			</t>
			<!-- AUTH CONTROL (composite) -->
			<t t-elif="controlType === 'auth'">
				<AuthControl
					value="value"
					onChange.bind="onAuthChange"
					inputContext="props.inputContext"
					suggestionsByKey="suggestionsByKey"
					readonly="isReadonly"
				/>
			</t>
			<!-- BODY TYPE CONTROL (composite) -->
			<t t-elif="controlType === 'body_type'">
				<BodyTypeControl
					value="value"
					onChange.bind="onBodyTypeChange"
					inputContext="props.inputContext"
					suggestionsByKey="suggestionsByKey"
					readonly="isReadonly"
				/>
			</t>
			<!-- QUERY PARAMS CONTROL (keyvalue with toggle) -->
			<t t-elif="controlType === 'query_params'">
				<div class="control-keyvalue">
					<KeyValueTable
						pairs="value"
						onChange.bind="onKeyValueChange"
						inputContext="props.inputContext"
						keyPlaceholder="'Key'"
						valuePlaceholder="'Value'"
						keySuggestions="suggestions"
						valueSuggestions="valueSuggestions"
						expressionSuggestions="expressionSuggestions"
						suggestionsByKey="suggestionsByKey"
						lockedKeys="lockedKeys"
						pairModes="props.pairModes"
						onPairModeChange="onKeyValuePairModeChange"
						readonly="isReadonly"
					/>
				</div>
			</t>
			<!-- MODEL SELECT — ExpressionInput fixed mode with Odoo model autocomplete -->
			<t t-elif="controlType === 'model_select'">
				<ExpressionInput
					value="value"
					placeholder="placeholder"
					mode="'fixed'"
					toggleMode="'none'"
					suggestions="suggestions"
					valueSuggestions="valueSuggestions"
					onChange="(v) => this.onExpressionChange(v)"
					readonly="isReadonly"
				/>
			</t>
			<!-- DOMAIN — Odoo DomainSelector (field-aware, type-safe operators) -->
			<t t-elif="controlType === 'domain'">
				<DomainControl
					resModel="resModel"
					value="value"
					onChange="(v) => this.onExpressionChange(v)"
					readonly="isReadonly"
					inputContext="props.inputContext"
				/>
			</t>
			<!-- FIELD VALUES — visual field→value rows for create/write ops -->
			<t t-elif="controlType === 'field_values'">
				<FieldValuesControl
					resModel="resModel"
					operation="operation"
					value="value"
					onChange="(v) => this.onExpressionChange(v)"
					readonly="isReadonly"
					inputContext="props.inputContext"
				/>
			</t>
			<!-- TRIGGER FIELDS — model-aware checkbox grid for record-event triggers -->
			<t t-elif="controlType === 'trigger_fields'">
				<TriggerFieldsControl
					value="value"
					suggestions="suggestions"
					onChange.bind="onTriggerFieldsChange"
					readonly="isReadonly"
				/>
			</t>
		</div>
	</t>
</templates>
