<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="workflow_studio.ConfigPanel">
		<div class="node-config-panel d-flex flex-column h-100" t-on-wheel.stop="">
			<t t-call="{{ constructor.subTemplates.header }}"/>
			<div class="node-config-content row g-0" t-att-class="{ 'execution-view-mode': isExecutionView, 'node-config-content--trigger': isTriggerNode, 'node-config-content--show-input': showInputColumn, 'node-config-content--show-output': showOutputColumn, 'node-config-content--input-rail': inputRailVisible, 'node-config-content--output-rail': outputRailVisible }">
				<t t-call="{{ constructor.subTemplates.input }}"/>
				<t t-call="{{ constructor.subTemplates.config }}"/>
				<t t-call="{{ constructor.subTemplates.output }}"/>
			</div>
		</div>
	</t>

	<t t-name="workflow_studio.ConfigPanel.Header">
		<!-- Single-row header: [icon · title] [Execute] [trigger actions] [←][→][×] -->
			<div class="ncp-header d-flex align-items-stretch border-bottom" t-att-class="{ 'ncp-header--trigger': isTriggerNode }">

			<!-- IDENTITY: node icon + title -->
				<div class="ncp-header-identity d-flex align-items-center flex-grow-1 min-w-0">
				<div class="ncp-node-icon-badge flex-shrink-0">
					<i t-att-class="'fa ' + nodeIcon"/>
				</div>
				<div class="ncp-title-group min-w-0 flex-grow-1">
					<div class="ncp-title fw-semibold">
						<t t-if="canEditNodeTitle">
							<input type="text" class="ncp-title-input" t-att-value="nodeNameInputValue" placeholder="Enter node name..." t-on-input="onNodeNameChange"/>
						</t>
						<t t-else="">
							<span class="text-truncate d-block" t-esc="nodeTitle"/>
						</t>
					</div>
				</div>
			</div>

			<!-- EXECUTE (flush separator + full-height btn) -->
			<t t-if="showHeaderExecute">
				<div class="ncp-header-sep"/>
				<button class="ncp-execute-btn btn btn-success d-flex align-items-center gap-2" t-on-click="onExecute" type="button" title="Execute up to this node">
					<i class="fa fa-play"/>
					<span>Execute</span>
				</button>
			</t>

			<!-- ACTIONS: trigger-only controls -->
			<t t-if="isTriggerNode">
				<div class="ncp-header-sep"/>
				<div class="ncp-header-actions d-flex align-items-stretch">
					<t t-foreach="triggerHeaderButtons" t-as="button" t-key="button.id">
						<button class="ncp-execute-btn ncp-trigger-action-btn btn d-flex align-items-center gap-2" t-att-class="button.className" t-on-click="button.onClick" t-att-disabled="button.disabled ? 'disabled' : undefined" type="button">
							<i t-if="button.icon" t-att-class="'fa ' + button.icon + ' me-1'"/>
							<t t-esc="button.label"/>
						</button>
					</t>
				</div>
			</t>

			<div class="ncp-header-sep"/>
			<div class="ncp-header-nav-cluster d-flex align-items-stretch">
				<t t-if="props.onNavigateToNode">
					<t t-set="prevNav" t-value="previousNavigation"/>
					<t t-if="prevNav.hasMultiple">
						<Dropdown manual="true" holdOnHover="true" state="getNavDropdownState('previous')" menuClass="'ncp-nav-popover ncp-nav-popover--previous'" position="'bottom-start'" onOpened="() => this.onNavDropdownOpened('previous')">
							<button type="button" class="ncp-nav-btn" t-att-class="{ 'is-open': getNavDropdownState('previous').isOpen }" title="Previous nodes" t-on-click="(ev) => this.onPrimaryNavClick('previous', ev)" t-on-mouseenter="(ev) => this.onNavTriggerMouseEnter('previous', ev)" t-on-mouseleave="() => this.onNavTriggerMouseLeave('previous')">
								<i class="fa fa-arrow-left"/>
								<i class="fa fa-caret-down ncp-nav-caret"/>
							</button>
							<t t-set-slot="content">
								<div class="ncp-nav-dropdown" t-att-style="getNavMenuStyle('previous')" t-on-mouseenter="() => this.onNavMenuMouseEnter('previous')" t-on-mouseover="(ev) => this.onNavMenuMouseOver('previous', ev)" t-on-mouseleave="() => this.onNavMenuMouseLeave('previous')">
									<t t-foreach="prevNav.options" t-as="opt" t-key="opt.key">
										<DropdownItem class="getNavItemClass('previous', opt)" attrs="getNavItemAttrs('previous', opt)" onSelected="() => this.onNavOptionSelected('previous', opt)">
											<span class="ncp-nav-dd-main">
												<span class="ncp-nav-dd-title" t-esc="opt.title"/>
												<span t-if="opt.socketLabel" class="ncp-nav-dd-meta" t-esc="opt.socketLabel"/>
											</span>
											<span t-if="isPrimaryNavOption('previous', opt)" class="ncp-nav-dd-default">Default</span>
										</DropdownItem>
									</t>
								</div>
							</t>
						</Dropdown>
					</t>
					<button t-elif="prevNav.primary" type="button" class="ncp-nav-btn" title="Previous node" t-on-click="() => this.onNavigateToNode(prevNav.primary.nodeId)">
						<i class="fa fa-arrow-left"/>
					</button>
					<button t-else="" type="button" class="ncp-nav-btn is-disabled" disabled="disabled" title="No previous node">
						<i class="fa fa-arrow-left"/>
					</button>
					<div class="ncp-header-sep"/>
					<t t-set="nextNav" t-value="nextNavigation"/>
					<t t-if="nextNav.hasMultiple">
						<Dropdown manual="true" holdOnHover="true" state="getNavDropdownState('next')" menuClass="'ncp-nav-popover ncp-nav-popover--next'" position="'bottom-end'" onOpened="() => this.onNavDropdownOpened('next')">
							<button type="button" class="ncp-nav-btn" t-att-class="{ 'is-open': getNavDropdownState('next').isOpen }" title="Next nodes" t-on-click="(ev) => this.onPrimaryNavClick('next', ev)" t-on-mouseenter="(ev) => this.onNavTriggerMouseEnter('next', ev)" t-on-mouseleave="() => this.onNavTriggerMouseLeave('next')">
								<i class="fa fa-arrow-right"/>
								<i class="fa fa-caret-down ncp-nav-caret"/>
							</button>
							<t t-set-slot="content">
								<div class="ncp-nav-dropdown" t-att-style="getNavMenuStyle('next')" t-on-mouseenter="() => this.onNavMenuMouseEnter('next')" t-on-mouseover="(ev) => this.onNavMenuMouseOver('next', ev)" t-on-mouseleave="() => this.onNavMenuMouseLeave('next')">
									<t t-foreach="nextNav.options" t-as="opt" t-key="opt.key">
										<DropdownItem class="getNavItemClass('next', opt)" attrs="getNavItemAttrs('next', opt)" onSelected="() => this.onNavOptionSelected('next', opt)">
											<span class="ncp-nav-dd-main">
												<span class="ncp-nav-dd-title" t-esc="opt.title"/>
												<span t-if="opt.socketLabel" class="ncp-nav-dd-meta" t-esc="opt.socketLabel"/>
											</span>
											<span t-if="isPrimaryNavOption('next', opt)" class="ncp-nav-dd-default">Default</span>
										</DropdownItem>
									</t>
								</div>
							</t>
						</Dropdown>
					</t>
					<button t-elif="nextNav.primary" type="button" class="ncp-nav-btn" title="Next node" t-on-click="() => this.onNavigateToNode(nextNav.primary.nodeId)">
						<i class="fa fa-arrow-right"/>
					</button>
					<button t-else="" type="button" class="ncp-nav-btn is-disabled" disabled="disabled" title="No next node">
						<i class="fa fa-arrow-right"/>
					</button>
					<div class="ncp-header-sep"/>
				</t>
				<button class="ncp-nav-btn ncp-nav-btn--close" t-on-click="onClose" title="Close" type="button">
					<i class="fa fa-times"/>
				</button>
			</div>

		</div>
	</t>

	<t t-name="workflow_studio.ConfigPanel.Input">
		<t t-if="!isTriggerNode">
			<div class="node-config-col-input d-flex flex-column" t-att-class="{ 'node-config-col--collapsed': inputRailVisible }">
				<t t-if="inputRailVisible">
					<button type="button" class="col-panel-rail" t-on-click="() => this.toggleSidePanel('input')" aria-label="Expand Input panel" title="Expand Input panel">
						<i class="fa fa-database col-panel-rail__icon"/>
						<span class="col-panel-rail__label">Input</span>
						<i class="fa fa-angle-right col-panel-rail__chevron"/>
					</button>
				</t>
				<t t-else="">
				<div class="col-panel-header d-flex align-items-center justify-content-between text-uppercase small fw-semibold" t-att-class="{ 'col-panel-header--clickable': !isExecutionView }" t-on-click="() => this.collapsePanel('input')" title="Collapse Input panel" role="button">
					<div class="d-flex align-items-center gap-2">
						<i class="fa fa-database"/>
						<span>INPUT</span>
					</div>
					<div class="d-flex align-items-center gap-2">
						<t t-if="versionOptions.length > 0">
							<span class="output-item-count">Run <t t-esc="activeVersionIndex + 1"/> of <t t-esc="activeSocketEvents.length"/></span>
						</t>
						<i t-if="!isExecutionView" class="fa fa-angle-left col-panel-header__chevron"/>
					</div>
				</div>
			<div class="col-panel-content">
				<t t-if="leftPanelData and leftPanelData.length > 0">
					<t t-foreach="leftPanelData" t-as="item" t-key="item.rowKey">
						<div class="ancestor-node-section" t-att-class="{ collapsed: isSectionCollapsed(item.nodeId) }">
							<div class="ancestor-node-header" t-on-click="() => this.toggleAncestorSection(item.nodeId)">
								<i t-att-class="'fa ' + (isSectionCollapsed(item.nodeId) ? 'fa-chevron-right' : 'fa-chevron-down')"/>
								<i t-att-class="item.isInputNode ? 'fa fa-sign-in' : 'fa fa-cube'"/>
								<span t-esc="item.data.title"/>
							</div>
							<div class="ancestor-node-data" t-if="!isSectionCollapsed(item.nodeId) and item.data.json !== undefined">
								<JsonTreeNode data="item.data.json" path="[]" level="0" initialExpandDepth="inputTreeExpandDepth" autoCollapseChildrenThreshold="treeAutoCollapseChildrenThreshold" isInputNode="item.isInputNode" sourceNodeId="item.isInputNode ? null : item.nodeId" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
							</div>
							<div class="ancestor-node-data" t-elif="!isSectionCollapsed(item.nodeId)">
								<div class="input-data-empty">
									<span>No output data</span>
								</div>
							</div>
						</div>
					</t>
					<div class="ancestor-node-section context-section" t-att-class="{ collapsed: isSectionCollapsed('_context') }">
						<div class="ancestor-node-header" t-on-click="() => this.toggleAncestorSection('_context')">
							<i t-att-class="'fa ' + (isSectionCollapsed('_context') ? 'fa-chevron-right' : 'fa-chevron-down')"/>
							<i class="fa fa-code"/>
							<span>Variables and context</span>
						</div>
						<div class="ancestor-node-data" t-if="!isSectionCollapsed('_context')">
							<JsonTreeNode data="contextVariables" path="[]" level="0" initialExpandDepth="contextTreeExpandDepth" autoCollapseChildrenThreshold="treeAutoCollapseChildrenThreshold" draggable="true" isContextRoot="true" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
						</div>
					</div>
				</t>
				<t t-else="">
					<div class="input-data-empty input-data-hint">
						<i class="fa fa-database"/>
						<p>No input data</p>
						<span>Execute previous nodes to see data</span>
					</div>
				</t>
			</div>
			</t>
		</div>
	</t>
</t>

<t t-name="workflow_studio.ConfigPanel.Config">
	<t t-if="isTriggerNode">
		<div class="node-config-col-config node-config-col-config--trigger d-flex flex-column col-7">
			<t t-call="{{ constructor.subTemplates.triggerConfig }}"/>
		</div>
	</t>
	<t t-else="">
		<div class="node-config-col-config wf-container d-flex flex-column" t-att-class="{ 'col-4': isExecutionView, 'col-4': !isExecutionView, 'readonly-config': isExecutionView }">
			<t t-call="{{ constructor.subTemplates.genericConfig }}"/>
		</div>
	</t>
</t>

<t t-name="workflow_studio.ConfigPanel.GenericConfig">
	<TabNav tabs="tabDefs" activeTab="state.activeTab" onTabClick.bind="onTabClick">
		<div class="tab-content p-3">
			<t t-if="state.activeTab === 'parameters'">
					<div t-if="showPanelLayoutToolbar" class="node-config-parameter-toolbar">
						<div class="node-config-parameter-toolbar__copy">
							<span class="node-config-parameter-toolbar__eyebrow">About this node</span>
							<p class="node-config-parameter-toolbar__description" t-esc="nodeParameterDescription"/>
							<div class="node-config-parameter-toolbar__tip" t-if="nodeParameterTip">
								<i class="fa fa-lightbulb-o"/>
								<span t-esc="nodeParameterTip"/>
							</div>
						</div>

					</div>
				<t t-foreach="groupedControls" t-as="group" t-key="group.key">
					<div class="node-config-section">
						<div class="node-config-section-title">
							<i t-att-class="'fa ' + (group.icon || 'fa-cube')"/>
							<span t-esc="group.name"/>
						</div>
							<t t-foreach="group.rows" t-as="row" t-key="row.id">
								<div class="ncp-control-row" t-att-class="row.className">
									<t t-if="row.kind === 'url-shell'">
										<div class="ncp-url-control__meta">
											<t t-foreach="row.cells" t-as="cell" t-key="cell.id + ':meta'">
												<div class="ncp-url-control__meta-item" t-att-class="cell.className">
													<span class="ncp-url-control__meta-label" t-esc="cell.control.label"/>
												</div>
											</t>
										</div>
									</t>
									<div class="ncp-control-row__body" t-att-class="row.kind === 'url-shell' ? 'ncp-url-control__body' : ''">
										<t t-foreach="row.cells" t-as="cell" t-key="cell.id">
											<div class="ncp-control-cell" t-att-class="cell.className">
												<ControlRenderer control="cell.control" onChange.bind="onControlChange" inputContext="expressionPreviewContext" mode="getControlMode(cell.control.key)" pairModes="getPairModes(cell.control.key)" onModeChange.bind="onControlModeChange" onPairModeChange.bind="onPairModeChange" readonly="isExecutionView" controlValues="state.controlValues"/>
											</div>
										</t>
									</div>
								</div>
						</t>
					</div>
				</t>
				<t t-if="groupedControls.length === 0">
					<div class="node-config-empty">No parameters to configure</div>
				</t>
			</t>
			<t t-if="state.activeTab === 'settings'">
				<div class="node-config-section">
					<div class="node-config-section-title">Node Settings</div>
					<div class="control-renderer">
						<label class="control-label">Node Name</label>
						<div class="d-flex align-items-center gap-2">
							<input type="text" class="control-input" t-att-value="nodeNameInputValue" placeholder="Enter node name..." t-on-input="onNodeNameChange" t-att-disabled="isExecutionView ? 'disabled' : undefined" t-att-readonly="isExecutionView ? 'readonly' : undefined"/>
							<button t-if="isAutoTitleNode and props.node.titleIsCustom and !isExecutionView" class="btn btn-outline-secondary btn-sm" type="button" t-on-click="onResetNodeName">Reset</button>
						</div>
					</div>
				</div>
			</t>
		</div>
	</TabNav>
</t>

<t t-name="workflow_studio.ConfigPanel.TriggerConfig">
	<div class="trigger-config-panel d-flex flex-column h-100">
		<TabNav tabs="tabDefs" activeTab="state.activeTab" onTabClick.bind="onTabClick">
			<div class="tab-content trigger-config-tab-content p-0 d-flex flex-column h-100">
					<div class="trigger-config-panel__body flex-grow-1 overflow-auto">
					<t t-if="state.activeTab === 'parameters'">
						<div t-if="state.triggerLoading" class="trigger-panel-state text-center text-muted py-5">
							<i class="fa fa-spinner fa-spin me-2"/>
 Loading trigger details...</div>
						<t t-else="">
							<div t-if="state.triggerErrorMessage" class="alert alert-danger" role="alert">
								<i class="fa fa-exclamation-circle me-2"/>
								<span t-esc="state.triggerErrorMessage"/>
							</div>
							<t t-foreach="warnings" t-as="warning" t-key="warning">
								<div class="alert alert-warning" role="alert">
									<i class="fa fa-exclamation-triangle me-2"/>
									<span t-esc="warning"/>
								</div>
							</t>
							<t t-if="isManualTrigger" t-call="{{ constructor.subTemplates.triggerManual }}"/>
							<t t-if="isScheduleTrigger" t-call="{{ constructor.subTemplates.triggerSchedule }}"/>
							<t t-if="isWebhookTrigger" t-call="{{ constructor.subTemplates.triggerWebhook }}"/>
							<t t-if="isRecordEventTrigger" t-call="{{ constructor.subTemplates.triggerRecordEvent }}"/>
						</t>
					</t>
					<t t-if="state.activeTab === 'settings'">
						<div class="node-config-section trigger-config-settings-section mb-0 border-0 pb-0">
							<div class="node-config-section-title">Trigger Settings</div>
							<div class="kv-row kv-row--stack trigger-control-stack mb-0">
								<div class="control-renderer mb-0">
									<label class="control-label">Node Name</label>
									<div class="d-flex align-items-center gap-2">
										<input type="text" class="control-input" t-att-value="nodeNameInputValue" placeholder="Enter node name..." t-on-input="onNodeNameChange" t-att-disabled="isExecutionView ? 'disabled' : undefined" t-att-readonly="isExecutionView ? 'readonly' : undefined"/>
										<button t-if="isAutoTitleNode and props.node.titleIsCustom and !isExecutionView" class="btn btn-outline-secondary btn-sm" type="button" t-on-click="onResetNodeName">Reset</button>
									</div>
								</div>
							</div>
						</div>
					</t>
				</div>
			</div>
		</TabNav>
	</div>
</t>

<t t-name="workflow_studio.ConfigPanel.TriggerControlGroups">
	<t t-foreach="triggerGroupedControls" t-as="group" t-key="group.key">
		<div class="trigger-control-group">
			<div t-if="group.controls.length > 0 and group.key !== 'general'" class="node-config-section-title trigger-control-group__title">
				<i t-att-class="'fa ' + (group.icon || 'fa-cube')"/>
				<span t-esc="group.name"/>
			</div>
				<t t-foreach="group.rows" t-as="row" t-key="row.id">
					<div class="ncp-control-row trigger-control-stack mb-3" t-att-class="row.className">
						<t t-foreach="row.cells" t-as="cell" t-key="cell.id">
							<div class="ncp-control-cell" t-att-class="cell.className">
								<ControlRenderer control="cell.control" onChange.bind="onControlChange" inputContext="expressionPreviewContext" mode="getControlMode(cell.control.key)" pairModes="getPairModes(cell.control.key)" onModeChange.bind="onControlModeChange" onPairModeChange.bind="onPairModeChange" readonly="isExecutionView" controlValues="state.controlValues"/>
							</div>
						</t>
				</div>
			</t>
		</div>
	</t>
</t>

<t t-name="workflow_studio.ConfigPanel.TriggerConfig.Manual">
	<section class="trigger-card">
		<div class="trigger-card__header">
			<h4>Manual trigger</h4>
			<p>Click <strong>Execute trigger</strong> to run this branch on demand. Save first to include latest graph changes.</p>
		</div>
		<div class="trigger-card__body">
			<ul class="trigger-facts mb-0">
				<li>Only this branch runs — other trigger paths are not activated.</li>
				<li>Output and execution telemetry appear in the right-hand debug surfaces.</li>
			</ul>
		</div>
	</section>
</t>

<t t-name="workflow_studio.ConfigPanel.TriggerConfig.Schedule">
	<section class="trigger-card">
		<div class="trigger-card__header">
			<h4>Schedule</h4>
			<p>Define the cadence that will be synced to the linked <code>ir.cron</code> record.</p>
		</div>
		<div class="trigger-card__body">
			<t t-call="workflow_studio.ConfigPanel.TriggerControlGroups"/>
		</div>
	</section>
</t>

<t t-name="workflow_studio.ConfigPanel.TriggerConfig.Webhook">
	<section class="trigger-card">
		<div class="trigger-card__header">
			<h4>Webhook behavior</h4>
		</div>
		<div class="trigger-card__body">
			<t t-call="workflow_studio.ConfigPanel.TriggerControlGroups"/>
		</div>
	</section>
	<section class="trigger-card">
		<div class="trigger-card__header d-flex align-items-center justify-content-between gap-3 flex-wrap">
			<div>
				<h4>Webhook URLs</h4>
			</div>
			<div class="d-flex align-items-center gap-2 flex-wrap">
				<button t-if="isProductionWebhookTab and !isExecutionView" class="btn btn-outline-secondary btn-sm" t-on-click="onRotateTriggerWebhook" t-att-disabled="state.triggerBusy ? 'disabled' : undefined" type="button">
					<i class="fa fa-refresh me-1"/>
 Rotate URL</button>
				<button t-if="isTestWebhookTab and !backendState.webhook_test_active and !isExecutionView" class="btn btn-primary btn-sm" t-on-click="onStartWebhookTest" t-att-disabled="state.triggerBusy ? 'disabled' : undefined" type="button">
					<i class="fa fa-headphones me-1"/>
 Listen for test event</button>
				<button t-if="isTestWebhookTab and backendState.webhook_test_active and !isExecutionView" class="btn btn-outline-danger btn-sm" t-on-click="onStopWebhookTest" t-att-disabled="state.triggerBusy ? 'disabled' : undefined" type="button">
					<i class="fa fa-stop me-1"/>
 Stop listening</button>
			</div>
		</div>
		<div class="trigger-card__body p-0">
			<TabNav tabs="webhookUrlTabs" activeTab="state.activeWebhookTab" onTabClick.bind="onWebhookTabClick">
				<div class="trigger-webhook-tabs p-3 d-flex flex-column gap-3">
					<t t-if="isProductionWebhookTab">
						<div class="small text-muted">Stable URL for live traffic. Rotate the secret if it may have leaked.</div>
						<UrlBox value="backendState.webhook_url" placeholder="'Activate to provision a production URL.'" label="'Production URL'" onCopy.bind="copyToClipboard"/>
					</t>
					<t t-if="isTestWebhookTab">
						<div class="d-flex align-items-center justify-content-between gap-3 flex-wrap">
							<div class="small text-muted">Temporary QA listener for manual testing. Payloads appear in the Output column.</div>
							<span class="trigger-badge trigger-badge--soft" t-att-class="backendState.webhook_test_active ? 'is-active' : 'is-inactive'">
								<t t-esc="backendState.webhook_test_active ? 'Listening' : 'Idle'"/>
							</span>
						</div>
						<UrlBox value="backendState.webhook_test_url" placeholder="'Click Listen for test event to generate a temporary URL.'" label="'Test URL'" tone="'success'" onCopy.bind="copyToClipboard"/>
						<div class="small text-muted">Last test payload: <t t-esc="lastTestTriggerLabel"/>
						</div>
					</t>
				</div>
			</TabNav>
		</div>
	</section>
</t>

<t t-name="workflow_studio.ConfigPanel.TriggerConfig.RecordEvent">
	<section class="trigger-card">
		<div class="trigger-card__header">
			<h4>Record event mapping</h4>
			<p>Configure this trigger directly in the editor, then sync it to the linked <code>base.automation</code> rule.</p>
		</div>
		<div class="trigger-card__body">
			<t t-call="workflow_studio.ConfigPanel.TriggerControlGroups"/>
			<div class="trigger-inline-note kv-row kv-row--stack mt-2">Creates or updates one automation rule bound to the chosen model.</div>
		</div>
	</section>
</t>

<t t-name="workflow_studio.ConfigPanel.Output">
	<t t-if="isTriggerNode">
		<div class="trigger-config-panel__output node-config-col-output col-5 d-flex flex-column border-start">
				<div class="col-panel-header d-flex align-items-center justify-content-between text-uppercase small fw-semibold">
					<div class="d-flex align-items-center gap-2">
						<i class="fa fa-terminal"/>
						<span t-esc="triggerOutputTitle"/>
						<t t-if="triggerHeaderStatusLabel">
							<span class="trigger-badge" t-att-class="triggerHeaderStatusClass" t-esc="triggerHeaderStatusLabel"/>
						</t>
					</div>
			</div>
			<div class="col-panel-content trigger-output-panel">
				<t t-if="isWebhookTrigger">
					<t t-if="hasWebhookTestPayload">
						<div class="output-tree-container trigger-output-tree">
							<JsonTreeNode data="backendState.webhook_last_test_payload" path="[]" level="0" initialExpandDepth="3" autoCollapseChildrenThreshold="40" draggable="false" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
						</div>
					</t>
					<t t-else="">
						<div class="input-data-empty output-empty-hint trigger-output-empty">
							<i class="fa fa-flask"/>
							<p>No test payload yet</p>
							<span>Start the listener, call the temporary URL, and the captured JSON will appear here.</span>
						</div>
					</t>
				</t>
				<t t-if="!isWebhookTrigger">
					<div class="input-data-empty output-empty-hint trigger-output-empty trigger-output-empty--compact">
						<i t-att-class="'fa ' + (isManualTrigger ? 'fa-play-circle' : isScheduleTrigger ? 'fa-clock-o' : 'fa-database')"/>
						<p t-esc="isManualTrigger ? 'Ready to run' : 'Backend status only'"/>
						<span t-esc="isManualTrigger ? 'Use Execute trigger to run this branch immediately.' : 'This trigger type exposes runtime state and linked-record metadata rather than a JSON payload.'"/>
					</div>
				</t>
			</div>
		</div>
	</t>
	<t t-else="">
		<div class="node-config-col-output wf-container d-flex flex-column" t-att-class="{ 'node-config-col--collapsed': outputRailVisible }">
			<t t-if="outputRailVisible">
				<button type="button" class="col-panel-rail" t-on-click="() => this.toggleSidePanel('output')" aria-label="Expand Output panel" title="Expand Output panel">
					<i class="fa fa-terminal col-panel-rail__icon"/>
					<span class="col-panel-rail__label">Output</span>
					<i class="fa fa-angle-left col-panel-rail__chevron"/>
				</button>
			</t>
			<t t-else="">
			<div class="col-panel-header d-flex align-items-center justify-content-between text-uppercase small fw-semibold" t-att-class="{ 'col-panel-header--clickable': !isExecutionView }" t-on-click="() => this.collapsePanel('output')" title="Collapse Output panel" role="button">
				<div class="d-flex align-items-center gap-2">
					<i class="fa fa-terminal"/>
					<span>OUTPUT</span>
					<t t-if="executionStatus !== 'idle'">
						<span class="execution-status-badge" t-att-class="'status-' + executionStatus">
							<i t-att-class="executionStatus === 'success' ? 'fa fa-check-circle' : executionStatus === 'error' ? 'fa fa-exclamation-circle' : 'fa fa-spinner fa-spin'"/>
							<span t-esc="executionStatus === 'success' ? 'Success' : executionStatus === 'error' ? 'Failed' : 'Running'"/>
						</span>
					</t>
				</div>
				<div class="d-flex align-items-center gap-2" t-on-click.stop="() => {}">
					<button t-if="!isExecutionView" class="pin-toggle-btn wf-btn wf-btn-ghost wf-btn-icon" t-att-class="{ 'pin-active': isNodePinned }" t-on-click="onTogglePin" t-att-disabled="isPinButtonDisabled ? 'disabled' : undefined" t-att-title="isNodePinned ? 'Unpin data (resume live execution)' : 'Pin output data (skip execution)'" type="button">
						<i t-if="state.pinBusy" class="fa fa-spinner fa-spin"/>
						<i t-else="" t-att-class="'fa ' + (isNodePinned ? 'fa-thumb-tack text-warning' : 'fa-thumb-tack')"/>
					</button>
					<t t-if="versionOptions.length > 0">
						<select class="output-version-select form-select form-select-sm" t-on-change="onVersionChange">
							<t t-foreach="versionOptions" t-as="opt" t-key="opt.index">
								<option t-att-value="opt.index" t-att-selected="opt.index === activeVersionIndex">Run <t t-esc="opt.label"/>
								</option>
							</t>
						</select>
					</t>
					<t t-if="executionDisplayResult">
						<span class="output-item-count" t-if="outputItemCount !== null">
							<t t-esc="outputItemCount"/>
 item<t t-if="outputItemCount !== 1">s</t>
						</span>
					</t>
					<i t-if="!isExecutionView" class="fa fa-angle-right col-panel-header__chevron"/>
				</div>
			</div>
			<div t-if="isNodePinned" class="pinned-data-banner wf-banner wf-banner-warning">
				<i class="pinned-data-banner__icon wf-banner-icon fa fa-thumb-tack"/>
				<div class="pinned-data-banner__body wf-banner-body">
					<span class="wf-banner-title">Pinned to saved run data</span>
					<p class="wf-banner-text">This node will skip runner execution in editor runs</p>
				</div>
				<button class="pinned-data-banner__dismiss wf-btn wf-btn-ghost wf-btn-icon wf-btn-sm" t-on-click="onTogglePin" t-att-disabled="state.pinBusy ? 'disabled' : undefined" title="Unpin" type="button">
					<i class="fa fa-times"/>
				</button>
			</div>
			<div t-if="outputSocketTabs.length > 0" class="output-socket-tabs">
				<div class="wf-toggle wf-toggle-sm">
					<t t-foreach="outputSocketTabs" t-as="tab" t-key="tab.id">
						<button type="button" class="output-socket-tab wf-toggle-item" t-att-class="{ active: tab.id === activeOutputSocket, 'is-active': tab.id === activeOutputSocket }" t-on-click="() => this.onOutputSocketClick(tab.id)">
							<t t-esc="tab.label"/>
						</button>
					</t>
				</div>
			</div>
			<div class="col-panel-content">
				<t t-if="executionDisplayResult">
					<t t-if="executionDisplayResult.error">
						<div class="output-error-banner">
							<i class="fa fa-exclamation-triangle"/>
							<span>Execution failed</span>
						</div>
						<div class="output-tree-container">
							<JsonTreeNode data="executionDisplayResult.error" path="[]" level="0" initialExpandDepth="outputTreeExpandDepth" autoCollapseChildrenThreshold="treeAutoCollapseChildrenThreshold" draggable="false" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
						</div>
					</t>
					<t t-else="">
						<div class="output-tree-container">
							<JsonTreeNode data="executionDisplayResult.output" path="[]" level="0" initialExpandDepth="outputTreeExpandDepth" autoCollapseChildrenThreshold="treeAutoCollapseChildrenThreshold" draggable="false" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
						</div>
					</t>
				</t>
				<t t-else="">
					<div class="input-data-empty output-empty-hint">
						<i class="fa fa-terminal"/>
						<p>No output yet</p>
						<span>Click <b>Execute</b> to run this node</span>
					</div>
				</t>
			</div>
			</t>
		</div>
	</t>
</t>
</templates>
