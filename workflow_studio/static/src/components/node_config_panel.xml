<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
	<t t-name="workflow_studio.node_config_panel">
		<!-- Backdrop -->
		<div class="node-config-backdrop d-flex justify-content-end" t-on-click="onBackdropClick" t-on-wheel.stop="">
			<!-- Panel -->
			<div class="node-config-panel d-flex flex-column" t-ref="panel" t-att-class="{ 'panel-expanded': state.isExpanded }" t-att-style="panelStyle" t-on-wheel.stop="">
				<!-- Drag Resize Handle -->
				<div class="panel-resize-handle" t-on-mousedown="onResizeStart" title="Drag to resize">
					<div class="resize-handle-bar"/></div>
				<!-- Header -->
				<div class="node-config-header d-flex align-items-center justify-content-between border-bottom">
					<div class="node-config-title d-flex align-items-center gap-2 fw-semibold">
						<i t-att-class="'fa ' + nodeIcon"/>
						<span t-esc="nodeTitle"/>
					</div>
					<div class="node-config-actions d-flex align-items-center gap-2">
						<!-- Execution Status Badge -->
						<t t-if="executionStatus !== 'idle'">
							<span class="execution-status-badge" t-att-class="'status-' + executionStatus">
								<i t-att-class="executionStatus === 'success' ? 'fa fa-check-circle' : executionStatus === 'error' ? 'fa fa-exclamation-circle' : 'fa fa-spinner fa-spin'"/>
								<span t-esc="executionStatus === 'success' ? 'Success' : executionStatus === 'error' ? 'Error' : 'Running'"/>
							</span>
						</t>
						<!-- Execute Node Button -->
						<button t-if="!isExecutionView" class="node-config-execute-btn btn btn-sm btn-success d-flex align-items-center gap-1" t-on-click="onExecute" type="button" title="Execute up to this node">
							<i class="fa fa-play"/> Execute
						</button>
						<!-- Expand/Collapse Toggle Button -->
						<button class="node-config-icon-btn node-config-expand-btn btn btn-sm btn-link p-0 border-0" t-on-click="onToggleExpand" t-att-title="state.isExpanded ? 'Collapse panel' : 'Expand to full width'" type="button">
							<i t-att-class="'fa ' + (state.isExpanded ? 'fa-compress' : 'fa-expand')"/>
						</button>
						<button class="node-config-icon-btn node-config-close btn btn-sm btn-link p-0 border-0" t-on-click="onClose" title="Close" type="button">
							<i class="fa fa-times"/>
						</button>
					</div>
				</div>
				<!-- Three Column Content -->
				<div class="node-config-content d-flex" t-att-class="{ 'execution-view-mode': isExecutionView }">
					<!-- LEFT COLUMN: Ancestor Node Outputs (Input) -->
					<div class="node-config-col-input d-flex flex-column">
						<div class="col-panel-header d-flex align-items-center justify-content-between text-uppercase small fw-semibold">
							<div class="d-flex align-items-center gap-2">
								<i class="fa fa-database"/>
								<span>INPUT</span>
							</div>
							<t t-if="versionOptions.length > 0">
								<span class="output-item-count">
									Run <t t-esc="activeVersionIndex + 1"/> of <t t-esc="activeSocketEvents.length"/>
								</span>
							</t>
						</div>
						<div class="col-panel-content">
							<!-- Show predecessor nodes with their outputs -->
							<t t-if="leftPanelData and leftPanelData.length > 0">
								<t t-foreach="leftPanelData" t-as="item" t-key="item.rowKey">
									<div class="ancestor-node-section" t-att-class="{ collapsed: isSectionCollapsed(item.nodeId) }">
										<div class="ancestor-node-header" t-on-click="() => this.toggleAncestorSection(item.nodeId)">
											<i t-att-class="'fa ' + (isSectionCollapsed(item.nodeId) ? 'fa-chevron-right' : 'fa-chevron-down')"/>
											<i t-att-class="item.isInputNode ? 'fa fa-sign-in' : 'fa fa-cube'"/>
											<t t-if="item.isInputNode">
												<span>
													<t t-esc="item.data.title"/>
												</span>
											</t>
											<t t-else="">
												<span t-esc="item.data.title"/>
											</t>
										</div>
										<div class="ancestor-node-data" t-if="!isSectionCollapsed(item.nodeId) and item.data.json !== undefined">
											<JsonTreeNode data="item.data.json" path="[]" level="0" initialExpandDepth="inputTreeExpandDepth" autoCollapseChildrenThreshold="treeAutoCollapseChildrenThreshold" isInputNode="item.isInputNode" sourceNodeId="item.isInputNode ? null : item.nodeId" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
										</div>
										<div class="ancestor-node-data" t-elif="!isSectionCollapsed(item.nodeId)">
											<div class="input-data-empty">
												<span>No output data</span>
											</div>
										</div>
									</div>
								</t>
								<!-- Variables and context section (always visible) -->
								<div class="ancestor-node-section context-section" t-att-class="{ collapsed: isSectionCollapsed('_context') }">
									<div class="ancestor-node-header" t-on-click="() => this.toggleAncestorSection('_context')">
										<i t-att-class="'fa ' + (isSectionCollapsed('_context') ? 'fa-chevron-right' : 'fa-chevron-down')"/>
										<i class="fa fa-code"/>
										<span>Variables and context</span>
									</div>
									<div class="ancestor-node-data" t-if="!isSectionCollapsed('_context')">
										<JsonTreeNode data="contextVariables" path="[]" level="0" initialExpandDepth="contextTreeExpandDepth" autoCollapseChildrenThreshold="treeAutoCollapseChildrenThreshold" draggable="true" isContextRoot="true" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
									</div>
								</div>
							</t>
							<t t-else="">
								<div class="input-data-empty input-data-hint">
									<i class="fa fa-database"/>
									<p>No input data</p>
									<span>Execute previous nodes to see data</span>
								</div>
							</t>
						</div>
					</div>
					<!-- CENTER COLUMN: Node Configuration -->
					<div class="node-config-col-config d-flex flex-column" t-att-class="{ 'readonly-config': isExecutionView }">
						<TabNav tabs="tabDefs" activeTab="state.activeTab" onTabClick.bind="onTabClick">
						<!-- Tab Content -->
						<div class="tab-content p-3">
							<!-- Parameters Tab -->
							<t t-if="state.activeTab === 'parameters'">
								<t t-foreach="groupedControls" t-as="group" t-key="group.key">
									<div class="node-config-section">
										<div class="node-config-section-title">
											<i t-att-class="'fa ' + (group.icon || 'fa-cube')"/>
											<span t-esc="group.name"/>
										</div>
										<t t-foreach="group.controls" t-as="control" t-key="control.key">
											<ControlRenderer control="control" onChange.bind="onControlChange" inputContext="expressionPreviewContext" mode="getControlMode(control.key)" pairModes="getPairModes(control.key)" onModeChange.bind="onControlModeChange" onPairModeChange.bind="onPairModeChange" readonly="isExecutionView" controlValues="state.controlValues"/>
										</t>
									</div>
								</t>
								<t t-if="groupedControls.length === 0">
									<div class="node-config-empty">
										No parameters to configure
									</div>
								</t>
							</t>
							<!-- Settings Tab -->
							<t t-if="state.activeTab === 'settings'">
								<div class="node-config-section">
									<div class="node-config-section-title">Node Settings</div>
									<div class="control-renderer">
										<label class="control-label">Node Name</label>
										<input type="text" class="control-input" t-att-value="props.node.title || ''" placeholder="Enter node name..." t-att-disabled="isExecutionView ? 'disabled' : undefined" t-att-readonly="isExecutionView ? 'readonly' : undefined"/>
									</div>
								</div>
							</t>
						</div>
						</TabNav>
					</div>
					<!-- RIGHT COLUMN: Output (always visible) -->
					<div class="node-config-col-output d-flex flex-column">
						<div class="col-panel-header d-flex align-items-center justify-content-between text-uppercase small fw-semibold">
							<div class="d-flex align-items-center gap-2">
								<i class="fa fa-terminal"/>
								<span>OUTPUT</span>
							</div>
							<div class="d-flex align-items-center gap-2">
								<!-- Version selector dropdown (when multiple executions for active socket) -->
								<t t-if="versionOptions.length > 0">
									<select class="output-version-select form-select form-select-sm" t-on-change="onVersionChange">
										<t t-foreach="versionOptions" t-as="opt" t-key="opt.index">
											<option t-att-value="opt.index" t-att-selected="opt.index === activeVersionIndex">
												Run <t t-esc="opt.label"/>
											</option>
										</t>
									</select>
								</t>
								<t t-if="executionDisplayResult">
									<span class="output-item-count" t-if="outputItemCount !== null">
										<t t-esc="outputItemCount"/> item<t t-if="outputItemCount !== 1">s</t>
									</span>
								</t>
							</div>
						</div>
						<!-- Socket tabs (when node has multiple output sockets) -->
						<div t-if="outputSocketTabs.length > 0" class="output-socket-tabs d-flex border-bottom">
							<t t-foreach="outputSocketTabs" t-as="tab" t-key="tab.id">
								<button type="button" class="output-socket-tab btn btn-sm btn-link text-decoration-none px-3 py-1 rounded-0 border-0"
									t-att-class="{ 'active fw-semibold border-bottom border-primary': tab.id === activeOutputSocket }"
									t-on-click="() => this.onOutputSocketClick(tab.id)">
									<t t-esc="tab.label"/>
								</button>
							</t>
						</div>
						<div class="col-panel-content">
							<t t-if="executionDisplayResult">
								<t t-if="executionDisplayResult.error">
									<div class="output-error-banner">
										<i class="fa fa-exclamation-triangle"/>
										<span>Execution failed</span>
									</div>
									<div class="output-tree-container">
										<JsonTreeNode data="executionDisplayResult.error" path="[]" level="0" initialExpandDepth="outputTreeExpandDepth" autoCollapseChildrenThreshold="treeAutoCollapseChildrenThreshold" draggable="false" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
									</div>
								</t>
								<t t-else="">
									<div class="output-tree-container">
										<JsonTreeNode data="executionDisplayResult.output" path="[]" level="0" initialExpandDepth="outputTreeExpandDepth" autoCollapseChildrenThreshold="treeAutoCollapseChildrenThreshold" draggable="false" resolveRecordRefs="actions.resolveRecordRefs" recordRefCache="state.recordRefCache" onRecordRefCachePatch.bind="onRecordRefCachePatch"/>
									</div>
								</t>
							</t>
							<t t-else="">
								<div class="input-data-empty output-empty-hint">
									<i class="fa fa-terminal"/>
									<p>No output yet</p>
									<span>Click <b>Execute</b> to run this node</span>
								</div>
							</t>
						</div>
					</div>
				</div>
				<!-- No footer — auto-save on config change -->
			</div>
		</div>
	</t>
</templates>
