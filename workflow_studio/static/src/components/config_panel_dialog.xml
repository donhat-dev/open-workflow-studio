<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="workflow_studio.ConfigPanelDialog">
        <Dialog
            size="'fs'"
            modalRef="modalRef"
            footer="false"
            header="false"
            withBodyPadding="true"
            contentClass="'wf-config-panel-dialog__content'"
            bodyClass="'wf-config-panel-dialog__body p-0'"
        >
            <NodeConfigPanel
                node="props.node"
                workflow="props.workflow"
                actions="props.actions"
                execution="props.execution"
                viewMode="props.viewMode"
                previousNavigation="previousNavigation"
                nextNavigation="nextNavigation"
                onNavigateToNode.bind="onNavigateToNode"
                onClose="props.close"
                onSave="safeOnSave"
            />
        </Dialog>
    </t>
</templates>
