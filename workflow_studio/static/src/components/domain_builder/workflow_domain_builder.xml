<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">

    <t t-name="workflow_studio.WorkflowDomainBuilder">
        <div class="o_domain_selector w-100" aria-atomic="true" t-att-class="props.className">
            <!-- Header: mode toggle button (always visible when editable) -->
            <t t-if="!props.readonly">
                <div class="d-flex justify-content-start mb-1">
                    <div class="btn-group btn-group-sm" role="group" aria-label="Domain mode toggle">
                        <button
                            class="btn px-2 text-start"
                            t-att-class="{ 'btn-primary': !isExpression, 'btn-outline-secondary': isExpression }"
                            title="Switch to domain tree builder"
                            t-on-click="switchToTree"
                            type="button"
                        >Tree</button>
                        <button
                            class="btn px-2 text-start"
                            t-att-class="{ 'btn-primary': isExpression, 'btn-outline-secondary': !isExpression }"
                            title="Switch to expression editor"
                            t-on-click="switchToExpression"
                            type="button"
                        >Expression</button>
                    </div>
                </div>
            </t>
            <t t-if="!isExpression">
                <t t-if="tree">
                    <WorkflowTreeEditor resModel="props.resModel"
                        tree="tree"
                        update.bind="update"
                        readonly="props.readonly"
                        isDebugMode="props.isDebugMode"
                        defaultConnector="props.defaultConnector"
                        getDefaultCondition.bind="getDefaultCondition"
                        getOperatorEditorInfo.bind="getOperatorEditorInfo"
                        getDefaultOperator.bind="getDefaultOperator"
                        getPathEditorInfo.bind="getPathEditorInfo"
                        inputContext="props.inputContext"
                    >
                        <CheckBox
                            t-if="showArchivedCheckbox"
                            value="includeArchived"
                            disabled="props.readonly"
                            className="'form-switch'"
                            onChange.bind="toggleIncludeArchived"
                        >
                            Include archived
                        </CheckBox>
                    </WorkflowTreeEditor>
                </t>
                <t t-else="">
                    <div class="o_domain_selector_row d-flex align-items-center">
                        This domain is not supported.
                        <t t-if="!props.readonly">
                            <button class="btn btn-sm btn-primary ms-2" t-on-click="() => this.resetDomain()">Reset domain</button>
                        </t>
                    </div>
                </t>
            </t>
            <!-- Row 1b: ExpressionInput — only in expression mode, separate from Code editor -->
            <t t-if="isExpression">
                <div class="o_domain_expression_row mt-2">
                    <ExpressionInput
                        value="props.domain"
                        onChange.bind="onExpressionChange"
                        onModeChange.bind="onExpressionInputModeChange"
                        multiline="true"
                        mode="'expression'"
                        toggleMode="'side'"
                        context="props.inputContext"
                    />
                </div>
            </t>

            <!-- Row 2: Code editor textarea (standalone, always below) -->
            <!-- Shows raw domain string in builder mode; shows stripped expression content in expression mode -->
            <t t-if="(props.isDebugMode and (!tree or !props.readonly)) or isExpression">
                <label class="o_domain_selector_debug_container d-block mt-3 border rounded p-3 bg-100 text-muted font-monospace">
                    <div class="mb-1">
                        <span class="small"># Code editor</span>
                    </div>
                    <textarea
                        class="pt-2 border-0 bg-transparent text-body"
                        type="text"
                        t-att-readonly="props.readonly"
                        spellcheck="false"
                        t-att-value="codeEditorDisplayValue"
                        t-on-input="(ev) => this.onDomainInput(ev.target.value)"
                        t-on-change="(ev) => this.onDomainChange(ev.target.value)"
                    />
                </label>
            </t>
        </div>
    </t>

</templates>
