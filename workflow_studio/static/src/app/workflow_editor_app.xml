<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="workflow_studio.workflow_editor_app">
        <div class="workflow-editor-app" t-att-class="{ 'history-open': isHistoryOpen }">
            <div class="editor-toolbar">
                <div class="editor-toolbar__left">
                    <button t-on-click="exit" class="editor-toolbar__exit btn btn-secondary" title="Back" style="min-width:42px; min-height:42px;">
                        <i class="oi oi-chevron-left"/>
                    </button>
                    <button class="editor-title-button" t-on-click="toggleWorkflowView">
                        <div class="editor-title" t-esc="workflowTitle"/>
                        <div class="editor-subtitle">
                            <t t-if="state.view === 'editor'">Workflow Editor</t>
                            <t t-else="">Workflow Details</t>
                        </div>
                    </button>
                </div>
                <div class="editor-actions" t-if="state.view === 'editor'">
                    <div class="editor-actions__group">
                        <button 
                            class="btn btn-outline-secondary"
                            t-att-class="{ active: isExecutionLogOpen }"
                            t-on-click="toggleExecutionLog"
                            title="Execution Logs">
                            <span class="btn__icon">
                                <i class="fa fa-list-ul"/>
                            </span>
                            Logs
                        </button>
                        <button 
                            class="btn btn-outline-secondary" 
                            t-on-click="openHistory"
                            title="Version History">
                            <span class="btn__icon">
                                <LucideIcon t-props="{ name: 'History', size: 16 }"/>
                            </span>
                            History
                        </button>
                    </div>
                </div>
            </div>
            <div class="editor-body">
                <t t-if="state.loading">
                    <div class="loading-spinner">
                        <p>Loading workflow...</p>
                    </div>
                </t>
                <t t-elif="state.error">
                    <div class="error-message">
                        <h3>Error</h3>
                        <p><t t-esc="state.error"/></p>
                    </div>
                </t>
                <t t-else="">
                    <div class="editor-container">
                        <t t-if="state.view === 'editor'">
                                <div class="editor-split">
                                <EditorCanvas/>
                                <WorkflowHistoryPanel
                                    t-if="isHistoryOpen"
                                    t-props="historyPanelProps"/>
                            </div>
                            <ExecutionLogPanel t-if="isExecutionLogOpen"/>
                        </t>
                        <t t-else="">
                            <div class="workflow-form-container">
                                <View t-props="workflowFormViewProps"/>
                                <Chatter threadModel="resModel" threadId="resId"/>
                            </div>
                        </t>
                    </div>
                </t>
            </div>
        </div>
    </t>
</templates>
