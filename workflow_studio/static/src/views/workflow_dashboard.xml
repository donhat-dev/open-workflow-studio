<?xml version="1.0" encoding="UTF-8"?>
<templates>
    <t t-name="workflow_studio.WorkflowDashboard">
        <div class="o_workflow_dashboard container-fluid py-3 border-bottom bg-view">
            <div class="row justify-content-between gap-3 gap-lg-0">
                <!-- Left: Workflow counts -->
                <div class="col-12 col-lg-5 flex-grow-1 flex-lg-grow-0 flex-shrink-0">
                    <!-- All Workflows -->
                    <div class="grid gap-4">
                        <div class="g-col-3 g-col-sm-2 d-flex align-items-center py-2 justify-content-end text-end justify-content-lg-start text-lg-start text-break">
                            All Workflows
                        </div>
                        <div class="g-col-9 g-col-sm-10 grid gap-1">
                            <div class="g-col-4 p-0" t-on-click="setSearchContext" title="Published Workflows" filter_name="filter_published">
                                <a href="#" class="btn btn-primary w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal">
                                    <div class="fs-2" t-out="data['all_published']"/>Published
                                </a>
                            </div>
                            <div class="g-col-4 p-0" t-on-click="setSearchContext" title="Draft Workflows" filter_name="filter_draft">
                                <a href="#" class="btn btn-primary w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal">
                                    <div class="fs-2" t-out="data['all_draft']"/>Draft
                                </a>
                            </div>
                            <div class="g-col-4 p-0" t-on-click="setSearchContext" title="All Workflows">
                                <a href="#" class="btn btn-primary w-100 h-100 border-0 rounded-0 text-capitalize text-break fw-normal opacity-75">
                                    <div class="fs-2" t-out="data['all_total']"/>Total
                                </a>
                            </div>
                        </div>
                    </div>
                    <!-- My Workflows -->
                    <div class="grid gap-4">
                        <div class="g-col-3 g-col-sm-2 d-flex align-items-center py-2 justify-content-end text-end justify-content-lg-start text-lg-start text-break">
                            My Workflows
                        </div>
                        <div class="g-col-9 g-col-sm-10 grid gap-2">
                            <div class="g-col-4 p-0" t-on-click="setSearchContext" title="My Published Workflows" filter_name="filter_published,filter_my">
                                <a href="#" class="btn btn-light d-flex align-items-center w-100 h-100 p-0 border-0 bg-100 fw-normal">
                                    <div class="w-100 p-2" t-out="data['my_published']"/>
                                </a>
                            </div>
                            <div class="g-col-4 p-0" t-on-click="setSearchContext" title="My Draft Workflows" filter_name="filter_draft,filter_my">
                                <a href="#" class="btn btn-light d-flex align-items-center w-100 h-100 p-0 border-0 bg-100 fw-normal">
                                    <div class="w-100 p-2" t-out="data['my_draft']"/>
                                </a>
                            </div>
                            <div class="g-col-4 p-0" t-on-click="setSearchContext" title="All My Workflows" filter_name="filter_my">
                                <a href="#" class="btn btn-light d-flex align-items-center w-100 h-100 p-0 border-0 bg-100 fw-normal">
                                    <div class="w-100 p-2" t-out="data['my_total']"/>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Right: Run metrics -->
                <div class="col-12 col-lg-7 col-xl-6 col-xxl-5 flex-shrink-0">
                    <div class="d-flex flex-column justify-content-between gap-2 h-100">
                        <div class="grid gap-2 h-100">
                            <div class="g-col-6 grid gap-1 gap-md-4">
                                <div class="g-col-12 g-col-sm-4 g-col-lg-6 d-flex align-items-center justify-content-center text-center justify-content-md-end text-md-end mt-4 mt-sm-0 text-break">
                                    Runs Today
                                </div>
                                <div class="g-col-12 g-col-sm-8 g-col-lg-5 d-flex align-items-center justify-content-center py-2 bg-100">
                                    <span class="fw-bold" t-out="data['all_runs_today']"/>
                                </div>
                            </div>
                            <div class="g-col-6 grid gap-1 gap-md-4">
                                <div class="g-col-12 g-col-sm-4 g-col-lg-6 d-flex align-items-center py-2 justify-content-center text-center justify-content-md-end text-md-end mt-4 mt-sm-0 text-break">
                                    Failed Today
                                </div>
                                <div class="g-col-12 g-col-sm-8 g-col-lg-6 d-flex align-items-center justify-content-center py-2 bg-100">
                                    <span class="fw-bold text-danger" t-out="data['all_failed_today']"/>
                                </div>
                            </div>
                        </div>
                        <div class="grid gap-2 h-100">
                            <div class="g-col-6 grid gap-1 gap-md-4">
                                <div class="g-col-12 g-col-sm-4 g-col-lg-6 d-flex align-items-center justify-content-center text-center justify-content-md-end text-md-end mt-4 mt-sm-0 text-break">
                                    Failure Rate (7d)
                                </div>
                                <div class="g-col-12 g-col-sm-8 g-col-lg-5 d-flex align-items-center justify-content-center py-2 bg-100">
                                    <span><t t-out="data['failure_rate_7d']"/>%</span>
                                </div>
                            </div>
                            <div class="g-col-6 grid gap-1 gap-md-4">
                                <div class="g-col-12 g-col-sm-4 g-col-lg-6 d-flex align-items-center py-2 justify-content-center text-center justify-content-md-end text-md-end mt-4 mt-sm-0 text-break">
                                    Avg Duration
                                </div>
                                <div class="g-col-12 g-col-sm-8 g-col-lg-6 d-flex align-items-center justify-content-center py-2 bg-100">
                                    <span t-out="data['all_avg_duration']"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
