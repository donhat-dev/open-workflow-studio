<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<data>
		<record id="action_workflow_editor_app" model="ir.actions.client">
			<field name="name">Workflow Editor</field>
			<field name="tag">workflow_studio.editor_app</field>
		</record>
		<!-- Client Action -->
		<record id="action_workflow_pilot_dev" model="ir.actions.client">
			<field name="name">Workflow Builder</field>
			<field name="tag">workflow_studio.dev_app</field>
		</record>
		<!-- Root Menu -->
		<record id="view_ir_workflow_list" model="ir.ui.view">
			<field name="name">ir.workflow.list</field>
			<field name="model">ir.workflow</field>
			<field name="arch" type="xml">
				<list>
					<field name="name"/>
					<field name="version"/>
					<field name="node_count"/>
					<field name="is_published"/>
					<field name="active"/>
					<field name="company_id"/>
				</list>
			</field>
		</record>
		<record id="view_ir_workflow_kanban" model="ir.ui.view">
			<field name="name">ir.workflow.kanban</field>
			<field name="model">ir.workflow</field>
			<field name="arch" type="xml">
				<kanban class="o_workflow_kanban" js_class="workflow_pilot_list_kanban" sample="1">
					<field name="name"/>
					<field name="description"/>
					<field name="version"/>
					<field name="node_count"/>
					<field name="is_published"/>
					<field name="active"/>
					<field name="published_at"/>
					<field name="user_id"/>
					<field name="activity_state"/>
					<field name="activity_ids"/>
					<templates>
						<t t-name="card">
							<widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
							<widget name="web_ribbon" title="Published" bg_color="text-bg-success" invisible="not is_published or not active"/>
							
							<div class="oe_kanban_global_click p-0 d-flex flex-column h-100 position-relative">
								<!-- Top Bar: Name + Actions -->
								<div class="d-flex justify-content-between align-items-start p-3 pb-0">
									<div class="o_kanban_record_top_left d-flex flex-column overflow-hidden me-2">
										<strong class="o_kanban_record_title fs-5 text-truncate" t-att-title="record.name.value">
											<field name="name"/>
										</strong>
										<div class="text-muted small mt-1 d-flex gap-2">
											<span class="badge text-bg-light border" title="Current Version">v<field name="version"/></span>
											<span class="badge text-bg-light border" title="Node Count"><field name="node_count"/> nodes</span>
										</div>
									</div>
									<div class="o_dropdown_kanban dropdown z-index-1">
										<a class="dropdown-toggle o-no-caret btn btn-sm btn-light border-0" role="button" data-bs-toggle="dropdown" href="#" aria-label="Dropdown menu" title="Settings">
											<i class="fa fa-ellipsis-v"/>
										</a>
										<div class="dropdown-menu" role="menu">
											<a role="menuitem" type="edit" class="dropdown-item">Configuration</a>
											<a role="menuitem" type="delete" class="dropdown-item text-danger">Delete</a>
										</div>
									</div>
								</div>

								<!-- Body: Description + Status -->
								<div class="o_kanban_record_body flex-grow-1 px-3 py-2 text-muted">
									<t t-if="record.description.raw_value">
										<field name="description" class="d-block small text-truncate" style="-webkit-line-clamp: 2; display: -webkit-box; -webkit-box-orient: vertical; white-space: normal;"/>
									</t>
									<t t-else="">
										<em class="text-muted opacity-50 small">No description</em>
									</t>
									
									<div class="mt-3" t-if="record.is_published.raw_value and record.active.raw_value">
										<div class="d-flex align-items-center text-success small" title="Published Date">
											<i class="fa fa-check-circle me-1"/>
											<span>Published <field name="published_at" widget="date"/></span>
										</div>
									</div>
								</div>

								<!-- Footer: Activities + Avatar -->
								<div class="o_kanban_record_bottom border-top px-3 py-2 mt-auto d-flex align-items-center justify-content-between bg-light-subtle rounded-bottom">
									<div class="oe_kanban_bottom_left">
										<field name="activity_ids" widget="kanban_activity"/>
									</div>
									<div class="oe_kanban_bottom_right">
										<field name="user_id" widget="many2one_avatar_user"/>
									</div>
								</div>
							</div>
						</t>
					</templates>
				</kanban>
			</field>
		</record>
		<record id="view_ir_workflow_form" model="ir.ui.view">
			<field name="name">ir.workflow.form</field>
			<field name="model">ir.workflow</field>
			<field name="arch" type="xml">
				<form string="Workflow">
					<header>
						<button name="action_save" string="Save" type="object" class="btn btn-primary"/>
					</header>
					<sheet>
						<group>
							<field name="name"/>
							<field name="description"/>
						</group>
						<group>
							<field name="active"/>
							<field name="auto_save"/>
							<field name="rollback_on_failure"/>
							<field name="is_published" readonly="1"/>
							<field name="version" readonly="1"/>
							<field name="node_count" readonly="1"/>
						</group>
						<notebook>
							<page string="Security" name="security">
								<group>
									<group string="Execution Context">
										<field name="run_as_user_id"/>
									</group>
									<group string="Model Access Control">
										<field name="model_allowlist" widget="text" placeholder='["sale.order", "stock.picking"]'/>
										<field name="model_denylist" widget="text" placeholder='["ir.%", "res.users"]'/>
									</group>
								</group>
							</page>
							<page string="Run" name="run">
								<group>
									<field name="run_ids" readonly="1">
										<list>
											<field name="name"/>
											<field name="status" widget="badge" 
												decoration-success="status == 'completed'"
												decoration-danger="status == 'failed'" 
												decoration-warning="status == 'running'" 
												decoration-info="status == 'pending'" 
												decoration-muted="status == 'cancelled'"/>
											<field name="started_at"/>
											<field name="completed_at"/>
											<field name="duration_seconds" string="Duration"/>
										</list>
									</field>
								</group>
							</page>
						</notebook>
					</sheet>
				</form>
			</field>
		</record>
		<record id="action_ir_workflow" model="ir.actions.act_window">
			<field name="name">Workflows</field>
			<field name="res_model">ir.workflow</field>
			<field name="view_mode">kanban,list,form</field>
			<field name="view_id" ref="view_ir_workflow_kanban"/>
		</record>
		<menuitem id="menu_workflow_pilot_root" name="Workflow Studio"/>
		<menuitem id="menu_ir_workflow" name="Workflows" parent="menu_workflow_pilot_root" action="action_ir_workflow" sequence="10"/>
	</data>
</odoo>
