<?xml version="1.0" encoding="utf-8"?>
<odoo>

		<record id="action_workflow_editor_app" model="ir.actions.client">
			<field name="name">Workflow Editor</field>
			<field name="tag">workflow_studio.editor_app</field>
		</record>
		<!-- Client Action -->
		<record id="action_workflow_pilot_dev" model="ir.actions.client">
			<field name="name">Workflow Builder</field>
			<field name="tag">workflow_studio.dev_app</field>
		</record>
		<!-- Search View -->
		<record id="view_ir_workflow_search" model="ir.ui.view">
			<field name="name">ir.workflow.search</field>
			<field name="model">ir.workflow</field>
			<field name="arch" type="xml">
				<search>
					<field name="name"/>
					<field name="user_id"/>
					<filter name="filter_published" string="Published" domain="[('is_published', '=', True)]"/>
					<filter name="filter_draft" string="Draft" domain="[('is_published', '=', False)]"/>
					<separator/>
					<filter name="filter_my" string="My Workflows" domain="[('user_id', '=', uid)]"/>
					<separator/>
					<filter name="filter_active" string="Active" domain="[('active', '=', True)]"/>
					<filter name="filter_archived" string="Archived" domain="[('active', '=', False)]"/>
					<group expand="0" string="Group By">
						<filter name="groupby_user" string="Owner" context="{'group_by': 'user_id'}"/>
						<filter name="groupby_published" string="Published" context="{'group_by': 'is_published'}"/>
					</group>
				</search>
			</field>
		</record>
		<!-- List View -->
		<record id="view_ir_workflow_list" model="ir.ui.view">
			<field name="name">ir.workflow.list</field>
			<field name="model">ir.workflow</field>
			<field name="arch" type="xml">
				<list js_class="workflow_dashboard_list">
					<field name="name"/>
					<field name="version"/>
					<field name="node_count"/>
					<field name="is_published"/>
					<field name="active"/>
					<field name="company_id"/>
				</list>
			</field>
		</record>
		<record id="view_ir_workflow_kanban" model="ir.ui.view">
			<field name="name">ir.workflow.kanban</field>
			<field name="model">ir.workflow</field>
			<field name="arch" type="xml">
				<kanban class="o_workflow_kanban o_base_automation_kanban_view" js_class="workflow_dashboard_kanban" sample="1">
					<field name="name"/>
					<field name="description"/>
					<field name="version"/>
					<field name="node_count"/>
					<field name="is_published"/>
					<field name="active"/>
					<field name="published_at"/>
					<field name="user_id"/>
					<field name="activity_state"/>
					<field name="activity_ids"/>
					<templates>
						<t t-name="card">
							<div class="d-flex align-items-center w-100 w-md-25 o_automation_base_info">
								<div class="d-flex flex-column">
									<strong class="o_kanban_record_title fs-5 text-truncate" t-att-title="record.name.value">
										<field name="name"/>
									</strong>
									<div class="text-muted small mt-1 d-flex gap-2">
										<span class="badge text-bg-light border" title="Current Version">v<field name="version"/>
										</span>
										<span class="badge text-bg-light border" title="Node Count">
											<field name="node_count"/>
											<span> nodes</span>
										</span>
										<span class="badge text-bg-success border" title="Published Date" t-if="record.is_published.raw_value and record.active.raw_value">
											<span>Published</span>
										</span>
									</div>
								</div>
							</div>
						</t>
					</templates>
				</kanban>
			</field>
		</record>
		<record id="view_ir_workflow_form" model="ir.ui.view">
			<field name="name">ir.workflow.form</field>
			<field name="model">ir.workflow</field>
			<field name="arch" type="xml">
				<form string="Workflow">
					<header>
						<button name="action_save" string="Save" type="object" class="btn btn-primary"/>
					</header>
					<sheet>
						<group>
							<field name="name"/>
							<field name="description"/>
						</group>
						<group>
							<field name="active"/>
							<field name="auto_save"/>
							<field name="rollback_on_failure"/>
							<field name="is_published" readonly="1"/>
							<field name="version" readonly="1"/>
							<field name="node_count" readonly="1"/>
						</group>
						<notebook>
							<page string="Security" name="security">
								<group>
									<group string="Execution Context">
										<field name="run_as_user_id"/>
									</group>
									<group string="Model Access Control">
										<field name="model_allowlist" widget="text" placeholder='["sale.order", "stock.picking"]'/>
										<field name="model_denylist" widget="text" placeholder='["ir.%", "res.users"]'/>
									</group>
								</group>
							</page>
							<page string="Run" name="run">
								<group>
									<field name="run_ids" readonly="1">
										<list>
											<field name="name"/>
											<field name="status" widget="badge" decoration-success="status == 'completed'" decoration-danger="status == 'failed'" decoration-warning="status == 'running'" decoration-info="status == 'pending'" decoration-muted="status == 'cancelled'"/>
											<field name="started_at"/>
											<field name="completed_at"/>
											<field name="duration_seconds" string="Duration"/>
										</list>
									</field>
								</group>
							</page>
						</notebook>
					</sheet>
				</form>
			</field>
		</record>
		<record id="action_ir_workflow" model="ir.actions.act_window">
			<field name="name">Workflows</field>
			<field name="res_model">ir.workflow</field>
			<field name="view_mode">kanban,list,form</field>
			<field name="path">workflows</field>
			<field name="view_id" ref="view_ir_workflow_kanban"/>
			<field name="search_view_id" ref="view_ir_workflow_search"/>
		</record>
		<!-- Dashboard Client Action (full page, Phase 3) -->
		<record id="action_workflow_dashboard" model="ir.actions.client">
			<field name="name">Dashboard</field>
			<field name="tag">workflow_studio.dashboard</field>
		</record>
		<menuitem id="menu_workflow_pilot_root" name="Workflow Studio" web_icon="workflow_studio,static/description/icon.png"/>
		<menuitem id="menu_workflow_dashboard" name="Dashboard" parent="menu_workflow_pilot_root" action="action_workflow_dashboard" sequence="5"/>
		<menuitem id="menu_ir_workflow" name="Workflows" parent="menu_workflow_pilot_root" action="action_ir_workflow" sequence="10"/>
</odoo>
